kTitle:{defaultMessage:"See Claude work",id:"RUmFmrpiOe"},firstTaskSubtitle:{defaultMessage:"Try a quick task \u2014 Claude does it, you watch",id:"9TBEFAOk73"},firstTaskPrompt:{defaultMessage:"Hey Claude, I just installed Cowork and want to see what you can do. Pick something simple and useful \u2014 summarize a short article from the web, draft a quick email, or run a small calculation. Keep it under a minute. Show me the result, then tell me one thing you could have done differently if I\u2019d given you more access.",id:"ZJjH5HWHFQ"},folderAccessTitle:{defaultMessage:"Point Claude at any folder",id:"XZGMsGmEx0"},folderAccessSubtitle:{defaultMessage:"So it can read and edit files on your computer",id:"vPUxWDxgsX"},folderAccessPrompt:{defaultMessage:"Hey Claude, I want to give you access to a folder on my computer. Please help me connect one. Once you\u2019re in, show me a few things you can now do with those files.",id:"XdgM0F6c25"},createProjectTitle:{defaultMessage:"Start a project",id:"u35RcZ81nC"},createProjectSubtitle:{defaultMessage:"Keep related tasks and context in one place",id:"yqwhqNNo2h"},connectToolTitle:{defaultMessage:"Connect your everyday tools",id:"aCCpuiyGU7"},connectToolSubtitle:{defaultMessage:"The more Claude knows your setup, the more it can do",id:"nVMbQAH3By"},connectToolPrompt:{defaultMessage:"Hey Claude, I\u2019m new to Cowork. Can you help me connect to my tools? First ask me which ones I use every day, and then help me connect them. Afterwards, give me ideas about what you can do with the new information you have.",id:"lMLtkuj/Ga"},installPluginTitle:{defaultMessage:"Customize Claude to your role",id:"tVTEVxlYhS"},installPluginSubtitle:{defaultMessage:"Add ready-made tools and workflows",id:"TSSIvgJO4U"},installPluginPrompt:{defaultMessage:"Hey Claude, I\u2019m new to Cowork. Can you help me find plugins to install? First ask me what my role is if you don\u2019t already know. Afterwards, suggest some plugins that match my role and sho