order-t-0.5 border-border-300 mx-2 transition-opacity"})]},s.name))}),t.jsx(mi,{href:`/customize/plugins/${encodeURIComponent(C.id)}`,onClick:e=>{0!==e.button||e.metaKey||e.ctrlKey||e.shiftKey||e.altKey||(e.preventDefault(),O(`/customize/plugins/${encodeURIComponent(C.id)}`))},className:"font-small text-text-500 hover:text-text-300 transition-colors mt-2 ml-2",children:t.jsx(LO,{defaultMessage:"See all",id:"078WAre0KU"})})]}):o.length>3||p?null:t.jsxs("section",{className:"w-full max-w-2xl mt-8 group/suggestions",children:[t.jsxs("div",{className:"flex items-center justify-between mb-2 px-2",children:[t.jsxs("button",{onClick:A,className:"flex items-center gap-2 font-small text-text-500 hover:text-text-100 transition-colors",children:[t.jsx(bG,{size:20}),t.jsx("span",{children:s.formatMessage(S.name)})]}),t.jsx("button",{onClick:L,"aria-label":s.formatMessage(Yoe.hideSuggestions),className:"text-text-500 hover:text-text-200 transition-colors opacity-0 group-hover/suggestions:opacity-100",children:t.jsx(Wm,{size:16})})]}),t.jsx("div",{className:"flex flex-col [&>button:hover+hr]:opacity-0 [&>hr:has(+button:hover)]:opacity-0",children:E.map((s,n)=>t.jsxs(e.Fragment,{children:[t.jsx(nle,{prompt:s,onSelect:F}),n<E.length-1&&t.jsx("hr",{className:"border-t-0.5 border-border-300 mx-2 transition-opacity"})]},s.id))}),!!n&&t.jsx(et,{variant:"ghost",size:"sm",onClick:D,className:"!text-text-500 mt-1",children:t.jsx(LO,{defaultMessage:"Customize with plugins",id:"i2yl4bVuRw"})})]})}const rle=a(Jm());var ole,lle;const cle=a(function(){if(lle)return ole;lle=1;const e=Xm();return ole=(t,s,n)=>e(s,t,n)}()),dle={releases:JSON.parse('[{"version":"1.20186.0","date":"2026-07-09","entries":[{"surface":"general","kind":"fix","text":"Fixed the app forgetting your last-used tab (for example Code) after an update or re-login."},{"surface":"general","kind":"fix","text":"Fixed `claude://` deep links being ignored when opening one launched the app from a closed state, including on Windows and Linux."},{"surface":"general","kind":"fix","text":"Fixed device attestation failing on Windows when sending several messages at once."},{"surface":"general","kind":"fix","text":"Fixed skill proposal and skill-file cards failing to save with \\"Couldn\'t save this skill\\" when a skill of that name already exists; they now offer \\"Update skill\\" and a replace confirmation."},{"surface":"general","kind":"fix","text":"Fixed garbled tool summaries in the transcript: descriptions that don\'t start with a recognized verb (for example \\"Final verification\\") now appear as written instead of being mis-conjugated."},{"surface":"general","kind":"fix","text":"Fixed the menu bar usage menu showing an empty progress bar for extra usage when the spend cap is unlimited."},{"surface":"code","kind":"fix","text":"Fixed a typed `<channel-message>` turn rendering as a spoofable \\"Message from `{server}`\\" card instead of as your own text."},{"surface":"code","kind":"feat","text":"Added a Troubleshooting option to import Claude Code CLI sessions found on this computer into the session list."},{"surface":"code","kind":"feat","text":"Added iOS Simulator and Android Emulator buttons to the session titlebar when the agent launches an app on a device, so the pane is one click to reopen."},{"surface":"code","kind":"fix","text":"Fixed cross-session messages going missing in the transcript: messages from another session no longer disappear when they arrive in the same turn as other content or when their envelope can\'t be fully parsed."},{"surface":"code","kind":"fix","text":"Fixed file links to files outside the working directory, including reports Claude writes to its scratchpad, showing \\"This file is outside the working directory\\" instead of opening."},{"surface":"code","kind":"fix","text":"Fixed the context window indicator and token count staying at the pre-compaction value after compacting a conversation."},{"surface":"cowork","kind":"fix","text":"Fixed admin-configured plugin marketplace sync failing behind corporate proxies on macOS."},{"surface":"cowork","kind":"fix","text":"Fixed the \\"Run this task while your Mac sleeps\\" setting turning itself off after an app update."},{"surface":"cowork","kind":"fix","text":"Fixed plugin connectors sometimes missing from the Connectors list and tool permission prompts when they were slow to start."},{"surface":"cowork","kind":"fix","text":"Fixed skills saved in a remote session sometimes still returning \\"Unknown command\\" right after saving."},{"surface":"3p","kind":"feat","text":"Added `*` wildcard matching for managed MCP `toolPolicy` keys; partial wildcard keys such as `\\"outlook_*\\"` in existing configurations now take effect, including any `allow` wildcards, which pre-approve the tools they match. Exact keys and the standalone `\\"*\\"` key behave as before."},{"surface":"3p","kind":"feat","text":"Added support for exporting Cowork task telemetry over `otlpProtocol: grpc` on macOS and Linux when no network proxy is configured."},{"surface":"3p","kind":"fix","text":"Fixed third-party settings ignoring managed configuration: the Claude Code pane now follows `isClaudeCodeForDesktopEnabled`, the Developer tab hides when `isLocalDevMcpEnabled` is off, and the Capabilities and Voice settings no longer appear."},{"surface":"3p","kind":"fix","text":"Fixed gateway-SSO bootstrap dropping cross-origin `managedMcpServers` entries, so admin-provisioned third-party connectors reach the app under device-code sign-in."},{"surface":"3p","kind":"fix","text":"Fixed sign-in timing out with identity providers (such as PingFederate) that redirect via a rendered page after authentication."},{"surface":"3p","kind":"fix","text":"Fixed Azure AI Foundry sessions failing with an authentication error on every message after interactive Microsoft Entra ID sign-in."},{"surface":"3p","kind":"fix","text":"Fixed MCP connectors failing to connect through gateways that optionally request a TLS client certificate, even though the connection test passed."}]},{"version":"1.19367.0","date":"2026-07-07","entries":[{"surface":"general","kind":"fix","text":"Fixed repeated crashes on Linux caused by unstable graphics acceleration; the app now turns acceleration off automatically and tells you."},{"surface":"general","kind":"fix","text":"Fixed the app becoming unresponsive when a session folder is on a slow or disconnected network drive."},{"surface":"general","kind":"fix","text":"Fixed bank payment-verification (3DS) pages not loading during checkout."},{"surface":"general","kind":"fix","text":"Fixed MCP connectors in artifacts being silently dropped; approving a connector now reliably grants its tools to the artifact, and a previously stuck approval heals itself the next time you approve."},{"surface":"general","kind":"feat","text":"Added automatic updates on Linux through the Anthropic apt repository, so new versions arrive with `apt upgrade` (and unattended upgrades where enabled)."},{"surface":"general","kind":"feat","text":"Added the ability to archive or delete the current chat, project, task, or coding session directly from the command palette ([[cmd+k]])."},{"surface":"code","kind":"fix","text":"Fixed freezes and stalls: while restoring a large number of sessions at startup, while builds or file syncs churned files inside a watched folder, and while the diff panel refreshed during a response."},{"surface":"code","kind":"fix","text":"Fixed newly trusted folders sometimes failing to start a session with a \\"workspace is not trusted\\" error."},{"surface":"code","kind":"fix","text":"Fixed \\"Open in Finder\\", \\"Open in editor\\", and \\"Attach to chat\\" doing nothing, or using the wrong path, for files in the diff panel when the session folder differs from the repo folder."},{"surface":"code","kind":"fix","text":"Fixed security-key and phone sign-ins not completing in preview tabs."},{"surface":"code","kind":"feat","text":"Added descriptive branch names for local Code sessions, derived from your first message, in place of the random adjective-noun names."},{"surface":"code","kind":"improvement","text":"Changed the default transcript and composer width to a narrower, more readable column; a width you already chose in Settings \u2192 Appearance is preserved."},{"surface":"cowork","kind":"feat","text":"Added keyboard access to the preview pane: Tab reaches a \\"Preview page\\" control, Enter moves focus into the loaded page, and `F6` (or `Ctrl+F6`) moves it back out."},{"surface":"cowork","kind":"fix","text":"Fixed Cowork offering terminal access, and showing an impossible fix suggestion, on devices whose operating system cannot provide the virtualization its isolated environment needs (such as ChromeOS), where every command immediately failed."},{"surface":"cowork","kind":"feat","text":"Added a copyright-access notice in the session timeline when Claude in Chrome first operates on certain news publisher sites."},{"surface":"3p","kind":"feat","text":"Added `inferenceFoundryAuthFlow` to choose how interactive Microsoft Entra ID sign-in for Azure AI Foundry runs: `device-code` (the default, which shows a code to enter at `microsoft.com/devicelogin`) or `browser`, which opens the system browser for an authorization-code (PKCE) sign-in."},{"surface":"3p","kind":"feat","text":"Added `microsoftAuthBroker`; set it to `disabled` to force browser-based Microsoft 365 sign-in instead of the native Company Portal or Windows account broker."},{"surface":"3p","kind":"improvement","text":"(breaking) Changed the default for Desktop Extensions (`.dxt` and `.mcpb`): they no longer load unless you set `isDesktopExtensionEnabled` to `true` in managed configuration. Previously they loaded by default and only the install UI was blocked."},{"surface":"3p","kind":"feat","text":"Added a `startupTimeoutSec` option for managed local (stdio) MCP servers and raised the default startup timeout from 10 to 120 seconds, fixing connection failures when a server command downloads packages on first run (for example `uvx` or `npx`)."},{"surface":"3p","kind":"feat","text":"Added support for background agents: long-running tasks now stay signed in after your identity provider\'s access token expires."},{"surface":"3p","kind":"improvement","text":"Updated `allowedPluginMarketplaces` (beta) so it can be delivered per-user through the bootstrap server; a response that omits the key leaves MDM-provisioned marketplaces in place."},{"surface":"3p","kind":"feat","text":"Added the ability for administrators to grant Microsoft 365 write scopes (send mail; edit calendars and files; send Teams chat; mailbox settings) through managed configuration."},{"surface":"3p","kind":"fix","text":"Fixed bundled Microsoft 365 and other MCP connectors failing to connect on networks with corporate TLS inspection (custom root CA)."},{"surface":"3p","kind":"fix","text":"Fixed the Microsoft 365 connector failing to sign in on Macs enrolled with Microsoft Company Portal."},{"surface":"3p","kind":"fix","text":"Fixed managed MCP connectors failing with a credential-storage error when the server allows anonymous access."},{"surface":"3p","kind":"fix","text":"Fixed a one-time loss of sign-ins on some managed Windows machines after app data moved to a new location."},{"surface":"3p","kind":"fix","text":"Fixed AWS credentials not reaching the Code tab\'s terminal for Amazon Bedrock configurations that use IAM Identity Center."},{"surface":"3p","kind":"fix","text":"Fixed the setup form incorrectly showing \\"Blocked address\\" for internal MCP or OAuth servers on IPv6 enterprise networks."},{"surface":"3p","kind":"fix","text":"Fixed connection tests reporting false failures: the test now runs MCP helper scripts and checks managed configurations exactly as saved, and uses the same Azure AI Foundry endpoint that sessions use."},{"surface":"3p","kind":"feat","text":"Added a \\"session expires soon\\" warning for Bedrock SSO and AWS-profile sign-in so you can re-authenticate before hitting an error."}]},{"version":"1.18286.2","date":"2026-07-07","entries":[{"surface":"general","kind":"improvement","text":"Updated the embedded Claude Code engine to the latest version."}]},{"version":"1.18286.0","date":"2026-07-02","entries":[{"surface":"general","kind":"fix","text":"Fixed remote SSH sessions getting stuck in a reconnect loop on very large messages, being lost when the computer woke from sleep mid-reconnect, and occasionally sending the same input twice after reconnecting."},{"surface":"general","kind":"fix","text":"Fixed being asked to sign in repeatedly after a session expired while you were using the app; your in-progress message draft now returns when you sign back in within 10 minutes, and signing out still clears it."},{"surface":"general","kind":"fix","text":"Fixed setup on Windows getting stuck retrying a download when the download folder was locked or inaccessible."},{"surface":"general","kind":"fix","text":"Fixed being unable to disable, delete, or uninstall plugins from GitHub-connected marketplaces, or to remove those marketplaces."},{"surface":"general","kind":"fix","text":"Fixed pressing Enter not sending your message when an @mention had no matching results."},{"surface":"general","kind":"fix","text":"Fixed `apt update` failing on Linux after uninstalling a Claude that was installed from the apt repository."},{"surface":"general","kind":"fix","text":"Fixed the file-open spinner on Linux staying up after the download completed."},{"surface":"code","kind":"fix","text":"Fixed Remote Control sessions spinning forever with no error after you sent a message when the hosting computer was no longer connected."},{"surface":"code","kind":"fix","text":"Fixed the sidebar project + button opening an empty prompt (or pointing at github.com) for GitHub Enterprise repositories."},{"surface":"code","kind":"improvement","text":"Improved the Code tab\'s live preview: it now reports honest connection and loading status (including when a page arrives but never finishes loading, or a server overloads itself with requests), adds browser-style Back, Forward, and Reload/Stop controls, and lets you close other preview tabs."},{"surface":"code","kind":"fix","text":"Fixed background tasks and workflows continuing to show as running after they finished, the session restarted, or the session was stopped."},{"surface":"code","kind":"feat","text":"Added a \\"Choose folder\\" option to recover a session whose working folder is missing: the conversation forks into the folder you pick and the stuck session is archived."},{"surface":"code","kind":"feat","text":"Added drag-to-reorder for queued messages, and Steer now works for messages that include images."},{"surface":"code","kind":"feat","text":"Added a \\"Switch organization\\" option on the \\"session not found\\" page so you can reopen a session link under the right organization."},{"surface":"cowork","kind":"fix","text":"Fixed document tools in cloud sessions acting on your local files instead of the session\'s files."},{"surface":"cowork","kind":"fix","text":"Fixed dictation dropping back to the text box when started from the mic button in existing sessions."},{"surface":"cowork","kind":"fix","text":"Fixed Computer Use teach mode where the Next and Exit buttons sometimes stopped responding until you switched apps and back, and cleared up teach-mode visuals so the screen-edge glow no longer flickers and the status indicator no longer sticks after you exit a guide."},{"surface":"cowork","kind":"feat","text":"Added click-to-zoom and drag-to-pan to the fullscreen image viewer."},{"surface":"3p","kind":"improvement","text":"Removed automatic addition of Anthropic\'s default plugin marketplace on third-party deployments, and removed the `disableDefaultPlugins` managed configuration key (which had no effect there). Provision marketplaces via `allowedPluginMarketplaces` (beta)."},{"surface":"3p","kind":"feat","text":"Added a usage breakdown by model family, source attribution, and usage tips to the `/usage` card."}]},{"version":"1.17377.2","date":"2026-07-01","entries":[{"surface":"3p","kind":"feat","text":"Added Claude Fable 5 to the model picker for organizations with access."}]},{"version":"1.17377.1","date":"2026-06-30","entries":[{"surface":"general","kind":"feat","text":"Added Linux support: Claude Desktop is now available for Debian and Ubuntu on x64 and arm64, installable as a .deb package."},{"surface":"general","kind":"improvement","text":"Updated the plugin Directory to show admin-configured marketplaces under the Organization tab and refresh them automatically when the source repository updates."},{"surface":"general","kind":"fix","text":"Fixed plugin and skill downloads stalling for several minutes on a dead connection before retrying; stalled downloads now retry sooner."},{"surface":"general","kind":"fix","text":"Fixed prompt and tool-detail content missing from OpenTelemetry exports for standard deployments that have not set an explicit content-capture policy; third-party deployments are unchanged."},{"surface":"general","kind":"improvement","text":"Changed zoom in and out to use smaller steps for finer control."},{"surface":"code","kind":"feat","text":"Added an integrated terminal pane and inline image previews in the transcript for SSH sessions."},{"surface":"code","kind":"feat","text":"Added step-by-step progress and a Stop button while a session\'s worktree is being set up, so a long checkout on a large repository can be cancelled."},{"surface":"code","kind":"feat","text":"Added a right-click menu in the Terminal pane with Copy, Paste, and Attach selection as context."},{"surface":"code","kind":"improvement","text":"Updated the transcript to mask API keys and tokens by default; click the eye icon to reveal them."},{"surface":"code","kind":"fix","text":"Fixed folder access and cross-session requests being rejected after you approved them when permission mode was Auto or Bypass permissions."},{"surface":"code","kind":"fix","text":"Fixed failed mid-turn message sends (for example, while offline) dropping your text instead of returning it to the input."},{"surface":"code","kind":"fix","text":"Fixed new session worktrees branching from the currently checked-out branch instead of the repository\'s default branch, and archived sessions leaving their worktree folders on disk."},{"surface":"cowork","kind":"fix","text":"Fixed a crash when resuming sessions with malformed remote connector data on disk."},{"surface":"cowork","kind":"fix","text":"Fixed the workspace download restarting from zero after a network interruption; it now resumes from where it left off and retries automatically."},{"surface":"cowork","kind":"fix","text":"Fixed folder and file names containing a dollar sign being misread, which broke file references."},{"surface":"cowork","kind":"fix","text":"Fixed dictation immediately dropping back to the text input in existing sessions."},{"surface":"cowork","kind":"fix","text":"Fixed an error caused by Claude trying to read a document creation skill that was not available."},{"surface":"cowork","kind":"fix","text":"Fixed clicking a built-in workflow (such as `deep-research`) in the activity panel\'s Skills section showing an empty drawer instead of its name and source."},{"surface":"3p","kind":"feat","text":"Added the `allowedPluginMarketplaces` managed configuration key. Configured git repositories appear under the Directory\'s Organization tab."},{"surface":"3p","kind":"feat","text":"Added an optional `omitOfflineAccess` subfield to the `inferenceVertexWorkforceOidc` configuration. Enable it when an identity provider rejects the `offline_access` scope; the app then prompts for sign-in each time the identity provider token expires instead of refreshing silently."},{"surface":"3p","kind":"feat","text":"Added managed configuration support on Linux: administrators can provision settings in a root-owned `/etc/claude-desktop/managed-settings.json`, validated against the same schema as the macOS and Windows sources."},{"surface":"3p","kind":"fix","text":"Fixed claude.ai sign-in never completing on Windows when an enterprise inference provider is configured."},{"surface":"3p","kind":"fix","text":"Fixed subagents failing with an invalid model error on third-party inference providers."},{"surface":"3p","kind":"fix","text":"Fixed `inferenceModels[].supports1m` being ignored, restoring the 1M-context option in the model picker for Bedrock, Vertex, Foundry, and gateway providers."},{"surface":"3p","kind":"fix","text":"Fixed the Microsoft 365 connector showing an unexpected admin-consent prompt after updating on tenants with restrictive consent policies when the connector\'s Access setting was blank. Also updated the bundled connector with tools to read the signed-in user\'s profile and draft reply-all emails."},{"surface":"3p","kind":"improvement","text":"Improved expired sign-in handling for third-party inference providers and connectors: a sign-in prompt now appears whichever credential type expired, connector authentication errors are shown in Settings and inline in chat with a Reconnect action, and background Code sessions stay signed in across a credential refresh."},{"surface":"3p","kind":"fix","text":"Fixed several connector reliability issues: connectors silently stopping mid-session after an OAuth refresh failed instead of prompting to reconnect, connectors configured with both OAuth sign-in and custom headers failing to connect, and admin-configured connectors not appearing in a session until they were signed in."}]},{"version":"1.15962.2","date":"2026-06-30","entries":[{"surface":"general","kind":"improvement","text":"Updated the embedded Claude Code engine to the latest version."}]},{"version":"1.15962.1","date":"2026-06-26","prs":[57527,57530,58100],"entries":[{"surface":"3p","kind":"fix","text":"Fixed locally-configured stdio MCP servers being refused in third-party deployments that don\'t use MDM."},{"surface":"3p","kind":"fix","text":"Fixed third-party MCP connectors disconnecting on every app restart when the OAuth provider returns a non-standard refresh response."},{"surface":"3p","kind":"fix","text":"Fixed Microsoft 365 brokered sign-in failing with \\"No reply address provided\\" on managed Macs."}]},{"version":"1.15962.0","date":"2026-06-25","entries":[{"surface":"general","kind":"fix","text":"Fixed a crash on launch caused by an unusually large saved session."},{"surface":"general","kind":"fix","text":"Fixed the conversation jumping and the Progress panel flashing when opening a completed task."},{"surface":"general","kind":"improvement","text":"Improved keyboard navigation: a message\'s action buttons are now a single Tab stop, with arrow keys to move between them."},{"surface":"code","kind":"fix","text":"Fixed high background CPU usage when several Code sessions were open in the same large repository."},{"surface":"code","kind":"fix","text":"Fixed people without a Claude Code seat being sent to the marketing site from `/code`; they now see an in-app organization switcher."},{"surface":"code","kind":"feat","text":"Added support for custom cron expressions when scheduling local routines."},{"surface":"code","kind":"feat","text":"Added \\"Open in VS Code\\", \\"Open in Cursor\\", and similar actions to the file panel, file tree, plan panel, titlebar, and sidebar in SSH sessions."},{"surface":"code","kind":"fix","text":"Fixed attachment cards for files that exist only inside a session doing nothing when clicked; they now open in the File pane, lightbox, Preview pane, or Files browser."},{"surface":"code","kind":"feat","text":"Added a \\"Load more\\" button to the All sessions list for people with many sessions."},{"surface":"cowork","kind":"fix","text":"Fixed workspace setup repeatedly failing with the same checksum error after a corrupted download, until the cache was cleared."},{"surface":"cowork","kind":"fix","text":"Fixed Cowork sessions losing their project after restarting the app."},{"surface":"cowork","kind":"feat","text":"Added a one-time prompt before Claude runs a dynamic workflow, explaining what workflows do."},{"surface":"cowork","kind":"improvement","text":"Improved the time it takes to start a session."},{"surface":"3p","kind":"feat","text":"Added a managed `websearch` built-in tool so self-hosted deployments can search the web. Admins configure Brave, Tavily, Exa, or a custom endpoint in managed config, and it is available in both the Cowork and Code tabs."},{"surface":"3p","kind":"feat","text":"Added an `otlpContentCapture` managed setting that lets admins opt in to sending specific categories of unredacted content \u2014 user prompts, assistant responses, tool inputs, tool outputs, and raw API request/response bodies \u2014 to their OTLP collector."},{"surface":"3p","kind":"improvement","text":"Updated the Microsoft 365 built-in connector\'s `scope` field to accept `MailboxSettings.Read`."},{"surface":"3p","kind":"fix","text":"Fixed managed connectors that lost their connection staying broken with failing tool calls; they now reconnect automatically on the next tool call, including from newly started conversations, and show a message if reconnecting fails."},{"surface":"3p","kind":"fix","text":"Fixed Microsoft 365 connector sign-in failing on Windows because of a broker error."},{"surface":"3p","kind":"fix","text":"Fixed a sign-in loop when your organization\'s gateway denies access; the app now shows \\"Access denied\\" and points you to your administrator."},{"surface":"3p","kind":"fix","text":"Fixed the selected model reverting after restarting the app and resuming a session."},{"surface":"3p","kind":"feat","text":"Added a `disableBundledSkills` managed config key that turns off Claude Code\'s bundled skills and workflows (such as `deep-research`) on that device."}]},{"version":"1.15200.0","date":"2026-06-23","entries":[{"surface":"code","kind":"feat","text":"Added an inline card for multiple-choice questions from Claude, so you can pick an option and step through each question before your choices are sent as a single reply."},{"surface":"code","kind":"fix","text":"Fixed the app crashing shortly after opening the Code tab when local session history files are very large."},{"surface":"code","kind":"fix","text":"Fixed the integrated terminal eventually failing to open new shells after the app had been running for several days on macOS."},{"surface":"code","kind":"fix","text":"Fixed forked sessions not carrying over pull requests from the original conversation, and pull request rows staying marked as closed after being reopened on GitHub."},{"surface":"code","kind":"fix","text":"Fixed the @-mention dropdown, side-chat panel, and plan-comment popover rendering, resizing, and dismissing in the wrong window when a session is opened in its own window."},{"surface":"code","kind":"fix","text":"Fixed an extra tab opening in the system browser when navigating with the Artifacts pane open."},{"surface":"cowork","kind":"feat","text":"Added the ability to delete Cowork sessions from the sidebar, recents, and Spaces views."},{"surface":"3p","kind":"feat","text":"Published the v2 bootstrap-response JSON schema (nested format). The v1 flat schema remains supported."},{"surface":"3p","kind":"improvement","text":"Removed support for installing connector extensions from local `.mcpb` and `.dxt` files."},{"surface":"3p","kind":"fix","text":"Fixed the Setup panel being locked when only the auto-update policy was deployed via MDM."},{"surface":"3p","kind":"fix","text":"Fixed connectors configured by your organization not appearing until restart after first sign-in."},{"surface":"3p","kind":"fix","text":"Fixed the model picker dropping to \\"Default model\\" mid-session when a gateway\'s model-list response was temporarily degraded."}]},{"version":"1.14271.0","date":"2026-06-18","entries":[{"surface":"general","kind":"fix","text":"Fixed the app prompting you to sign in again every day when your claude.ai session was more than a day old."},{"surface":"general","kind":"fix","text":"Fixed Claude Design links in chat navigating the app in place instead of opening Claude Design."},{"surface":"general","kind":"fix","text":"Fixed the app showing a blank window when a network proxy redirects the connection to Claude."},{"surface":"code","kind":"improvement","text":"Changed routines to count against your regular usage limits instead of a separate daily included-run limit, and removed the included-runs indicator."},{"surface":"code","kind":"improvement","text":"Updated the model picker to show restricted models as non-selectable with an explanatory badge, and to reflect your organization\'s allowed default model."},{"surface":"code","kind":"fix","text":"Fixed HTML and SVG file previews showing black text on a dark background in dark mode."},{"surface":"code","kind":"fix","text":"Fixed menus and popovers opening behind the preview panel."},{"surface":"cowork","kind":"fix","text":"Fixed Claude in Chrome file uploads failing for files in the session\'s shared folders and outputs."},{"surface":"cowork","kind":"fix","text":"Fixed scheduled tasks leaving earlier processes running after each scheduled run."},{"surface":"cowork","kind":"fix","text":"Fixed Windows file paths showing garbled characters in the folder access approval card, and reduced unnecessary folder access denials when allowed workspace folders are configured."},{"surface":"3p","kind":"improvement","text":"(breaking) Changed the `chatCodeExecutionEnabled` managed configuration key to `chatAdvancedFileAnalysisEnabled`. It still lets Claude analyze attached files such as spreadsheets and presentations by running code in a sandbox scoped to the session\'s attachments, and remains off by default. Update any managed configuration that sets the old key."},{"surface":"3p","kind":"improvement","text":"Deprecated the `betaFeaturesEnabled` managed configuration key; use the per-feature keys `chatTabEnabled` and `chatAdvancedFileAnalysisEnabled` instead. The Beta label in the Setup window is now informational only, and the Beta label has been removed from the built-in Microsoft 365 connector presets."},{"surface":"3p","kind":"feat","text":"Added the `inferenceSessionLifetimeSec` managed configuration key. Set it to your identity provider\'s session lifetime to show users a re-authenticate reminder before their sign-in expires."},{"surface":"3p","kind":"feat","text":"Added `~` and environment variable expansion (such as `%APPDATA%` and `%OneDriveCommercial%`) to the `allowedWorkspaceFolders` setting, so folder paths can vary per user."},{"surface":"3p","kind":"feat","text":"Added a per-folder pre-select option to `allowedWorkspaceFolders` so an administrator-configured folder can appear as a ready chip when users start a new task, and removed the \\"Create workspace folder?\\" prompt for administrator-configured folders."}]},{"version":"1.13576.0","date":"2026-06-16","entries":[{"surface":"general","kind":"improvement","text":"Improved find-in-page to search the entire session transcript instead of only the text scrolled into view, and the find bar now reliably takes keyboard focus when opened."},{"surface":"general","kind":"feat","text":"Added a unified Artifacts view that lists your chat, Code, and Cowork artifacts in one searchable place, with a \\"New artifact\\" menu and a \\"Filter by\\" control to narrow the list by source."},{"surface":"general","kind":"fix","text":"Fixed keyboard shortcut conflicts failing silently. Assigning a shortcut already held by another app now tells you and keeps your previous shortcut working, and Quick Entry registration errors now appear in Settings."},{"surface":"general","kind":"fix","text":"Fixed the first-run notification explaining that Claude keeps running in the notification area never appearing on Windows."},{"surface":"code","kind":"feat","text":"Added running dev servers to the Background tasks panel, with stop and open-preview actions."},{"surface":"code","kind":"improvement","text":"Improved the Code file viewer: images, video, and audio now play inline instead of showing as text, and Markdown, CSV, and image files refresh automatically when Claude edits them."},{"surface":"code","kind":"improvement","text":"Updated the model picker. The three headline models appear at the top level with older models and context-size variants under \\"More models\\", each model shows a capability description, and currently-unavailable models appear disabled instead of failing when selected."},{"surface":"code","kind":"improvement","text":"Updated the in-session artifact panel: switch between a session\'s published artifacts from the title dropdown, see when an artifact was last updated, copy a share link, and open, share, or delete the artifact from the overflow menu."},{"surface":"code","kind":"improvement","text":"Changed the Code sessions tab from \\"Projects\\" to \\"All sessions\\". It now lists your non-project sessions alongside project sessions and adds a multi-select Environment filter."},{"surface":"code","kind":"fix","text":"Fixed pull request status checks. Failures now show a small warning indicator on the branch row instead of repeated error popups, the \\"status couldn\'t be checked\\" warning appears less often and can always be dismissed, and only GitHub CLI sign-in problems still raise a notification."},{"surface":"cowork","kind":"fix","text":"Fixed corrupt plugin downloads crashing or hanging the app."},{"surface":"cowork","kind":"fix","text":"Fixed skills sometimes staying on an older version after being edited until toggled off and on."},{"surface":"3p","kind":"feat","text":"Added the Chat tab as a beta feature controlled by the `chatTabEnabled` managed configuration key. The separate `chatCodeExecutionEnabled` key lets Claude analyze attachments and create files such as spreadsheets and presentations by running code in an isolated sandbox scoped to the session\'s attachments, and is off by default."},{"surface":"3p","kind":"feat","text":"Added the `betaFeaturesEnabled` managed configuration key. Setting it to false disables every beta feature in the deployment, including the Chat tab."},{"surface":"3p","kind":"feat","text":"Added Bedrock Mantle as an inference provider option. It reuses the existing `inferenceBedrockRegion` and `inferenceBedrockBaseUrl` managed configuration keys and authenticates with a bearer token or a credential helper."},{"surface":"3p","kind":"feat","text":"Added `anthropicFamilyTier` and `isFamilyDefault` to managed `inferenceModels` entries. Tag each configured model with the Claude tier it stands in for so tier shortcuts like opus and sonnet resolve to your configured model IDs instead of the canonical names your provider may not route."},{"surface":"3p","kind":"feat","text":"Added the `inferenceBedrockAwsCliPath` managed configuration key to set the AWS CLI\'s absolute path. This fixes aws sso login failing when the app is launched from Finder on macOS and the CLI is not on the default search path."},{"surface":"3p","kind":"fix","text":"Fixed Google Workspace connectors never starting their OAuth sign-in. The MCP client identifier the app sends to connected servers is now `claude-desktop-3p`, changed from `custom3p-desktop`, so update any MCP server allowlists or log filters that match the old value."},{"surface":"3p","kind":"fix","text":"Fixed the managed Tool policy `*` entry being ignored. It now applies as the default for any tool not listed by name."},{"surface":"3p","kind":"fix","text":"Fixed organization plugins sometimes not opening from the Directory right after launch or update."},{"surface":"3p","kind":"fix","text":"Fixed several connection and sign-in issues: Bedrock sessions now prompt to sign in again after AWS IAM Identity Center expires instead of failing with repeated credential errors, remote MCP connectors no longer stay Connected after a non-refreshable access token expires, the connection test now passes against gateways that optionally request a TLS client certificate, signing in after signing out no longer needs a double click, and sign-in recovery no longer uses stale configuration after a server-side update or leaves the model picker empty until restart."}]},{"version":"1.12603.1","date":"2026-06-11","entries":[{"surface":"general","kind":"feat","text":"Added Find Next and Find Previous keyboard shortcuts to in-app search."},{"surface":"general","kind":"fix","text":"Fixed preview panes stealing keyboard focus from the chat input when they reloaded or navigated."},{"surface":"general","kind":"fix","text":"Fixed sessions failing to start after your sign-in expired \u2014 the app now prompts you to sign in again."},{"surface":"code","kind":"feat","text":"Added the Files panel to remote and SSH sessions \u2014 search the session\'s files and open them in the viewer \u2014 plus a Show in Files button in the file viewer."},{"surface":"code","kind":"feat","text":"Added a running-tasks button to the activity indicator that opens the Tasks panel, and Bash rows in the Background tasks panel now open to show their output, including a live tail while the command runs."},{"surface":"code","kind":"fix","text":"Fixed SSH sessions: forking no longer opens an empty conversation, and connections no longer fail with \\"Failed to upload file\\" errors on remotes first set up by early-2026 versions of the app."},{"surface":"code","kind":"fix","text":"Fixed renaming a session while its title was still generating \u2014 the generated title no longer overwrites the name you set."},{"surface":"code","kind":"fix","text":"Fixed the Pull Requests view showing \\"No open pull requests\\" when GitHub isn\'t connected \u2014 it now prompts you to connect."},{"surface":"code","kind":"feat","text":"Added model-picker memory \u2014 the picker now remembers your last model choice."},{"surface":"cowork","kind":"fix","text":"Fixed scheduled tasks firing many duplicate runs at once when the computer wakes from sleep."},{"surface":"cowork","kind":"fix","text":"Fixed remote sessions re-prompting for access to folders you had already trusted."},{"surface":"cowork","kind":"fix","text":"Fixed plugins becoming corrupted when they synced while you switched accounts."},{"surface":"3p","kind":"feat","text":"Added the built-in Microsoft 365 connector \u2014 admins can configure it from the Setup window\'s server presets. Users sign in through their browser, and Claude can search and read Microsoft 365 mail, calendar, OneDrive, and SharePoint. It requests read-only access by default; admins can grant additional read scopes, such as Teams channel messages and meeting transcripts, with the managed server entry\'s scope setting."},{"surface":"3p","kind":"improvement","text":"Deprecated the \\"sso\\" value for the inferenceGatewayAuthScheme managed configuration key in favor of inferenceCredentialKind \\"interactive\\" \u2014 existing configurations keep working and log a deprecation warning."},{"surface":"3p","kind":"feat","text":"Added the inferenceVertexOAuthLoginHint managed configuration key to pre-fill the Google account chooser when signing in to Vertex AI, so users in organizations federated to a third-party identity provider land on the right account automatically."}]},{"version":"1.12603.0","date":"2026-06-11","entries":[]},{"version":"1.11847.5","date":"2026-06-09","entries":[{"surface":"general","kind":"fix","text":"Fixed Clear Cache and Restart signing you out instead of just clearing caches."},{"surface":"general","kind":"fix","text":"Fixed mouse back and forward buttons not navigating on macOS for mice managed by driver software like Logitech Options+, and added trackpad swipe navigation."},{"surface":"general","kind":"fix","text":"Fixed organization plugins sometimes failing to open right after app launch, and the plugin directory now offers Install again after an uninstall."},{"surface":"general","kind":"fix","text":"Fixed connector, Chrome extension, and plugin toggles in the composer\'s \\"+\\" menu not responding when you click directly on the switch."},{"surface":"general","kind":"fix","text":"Fixed an issue where signing in could leave the app unable to start sessions until it was restarted."},{"surface":"general","kind":"fix","text":"Fixed shell-exported custom request headers not reaching Claude Code sessions."},{"surface":"code","kind":"fix","text":"Fixed Claude losing its coding instructions, file-link formatting, and worktree context after a session resumed from idle."},{"surface":"code","kind":"fix","text":"Fixed the preview pane sometimes connecting to an unrelated dev server that was already using the configured port, and it now reopens the dev server you last picked for each project."},{"surface":"code","kind":"improvement","text":"Improved responsiveness in Code sessions: smoother streaming of long code blocks, quicker side-panel shortcuts, and less delay opening cloud sessions with many screenshots."},{"surface":"code","kind":"fix","text":"Fixed popovers, dialogs, and the rewind picker not appearing \u2014 and typed characters jumping to the end of the composer \u2014 when a Code session is opened in its own window."},{"surface":"code","kind":"fix","text":"Fixed the slash-command menu opening behind the side chat panel."},{"surface":"code","kind":"fix","text":"Fixed the source-branch picker showing nothing for SSH sessions with worktree enabled."},{"surface":"cowork","kind":"feat","text":"Added a \\"Free Up Cowork Disk Space\\" option under Help > Troubleshooting, and Cowork now cleans up caches and old temporary files automatically when its workspace disk runs low."},{"surface":"cowork","kind":"improvement","text":"Improved the read/unread toggle on sidebar sessions: it now works on the currently open session, has a larger click target, and shows a tooltip describing what a click will do."},{"surface":"3p","kind":"feat","text":"Added support for the Fable model family, and for Mythos where your organization has access."},{"surface":"3p","kind":"fix","text":"Fixed sign-in failing with external identity providers that reject the offline_access scope \u2014 admins can now disable the automatic append."}]},{"version":"1.11847.0","date":"2026-06-08","entries":[]},{"version":"1.11187.4","date":"2026-06-05","entries":[{"surface":"general","kind":"fix","text":"Fixed reinstalling Claude on Windows failing after an uninstall when IT had installed it for all users."},{"surface":"general","kind":"fix","text":"Fixed the app not starting automatically at login on Windows."},{"surface":"general","kind":"feat","text":"Added a banner when an update fails to install, instead of failing silently."},{"surface":"general","kind":"fix","text":"Fixed built-in connectors staying disconnected after a crash \u2014 existing sessions now reconnect them automatically, and disconnecting a built-in connector now signs it out and keeps it disconnected across restarts."},{"surface":"code","kind":"feat","text":"Added math rendering for inline and block expressions in Claude Code transcripts."},{"surface":"code","kind":"feat","text":"Added Ultracode to the effort slider, which selects the highest effort level and turns on dynamic workflows for the session."},{"surface":"code","kind":"feat","text":"Added drag-to-reorder and A\u2192Z sorting for projects in the Claude Code sidebar."},{"surface":"code","kind":"feat","text":"Added triple-click to select a whole code block, plus right-click menu actions to copy a code block or inline code, in Claude Code transcripts."},{"surface":"code","kind":"fix","text":"Fixed resuming Code sessions when the working folder had moved or been deleted \u2014 sessions saved with a ~ path no longer show as missing or re-prompt for trust, and a deleted remote folder now reports clearly and offers a Fork session button instead of retrying in a loop."},{"surface":"cowork","kind":"feat","text":"Added a low-disk-space warning before Cowork downloads the files it needs to run."},{"surface":"cowork","kind":"feat","text":"Added in-session effort and thinking controls for local Cowork projects."},{"surface":"cowork","kind":"improvement","text":"Updated the New project folder picker to default to your Claude data folder (~/Claude/Projects) instead of ~/Documents."},{"surface":"cowork","kind":"fix","text":"Fixed Claude reporting that a skill was updated when the change was never saved to your account."},{"surface":"cowork","kind":"fix","text":"Fixed the /schedule command in Cowork showing as unavailable."},{"surface":"3p","kind":"fix","text":"Fixed managed connectors and SSO sign-in requesting broader OAuth scopes than the administrator configured."},{"surface":"3p","kind":"fix","text":"Fixed three Bedrock sign-in and session issues: SSO sign-in failing behind corporate proxies that intercept secure traffic, expired SSO tokens prompting a new sign-in every hour instead of refreshing automatically, and resumed sessions failing on their first message."}]},{"version":"1.11187.0","date":"2026-06-04","entries":[]},{"version":"1.10628.0","date":"2026-06-02","entries":[]},{"version":"1.9659.0","date":"2026-05-27","entries":[]},{"version":"1.9255.0","date":"2026-05-26","entries":[]},{"version":"1.8555.0","date":"2026-05-21","entries":[]},{"version":"1.8089.0","date":"2026-05-19","entries":[]},{"version":"1.7196.0","date":"2026-05-12","entries":[]},{"version":"1.6889.0","date":"2026-05-08","entries":[]},{"version":"1.6608.0","date":"2026-05-07","entries":[]},{"version":"1.6259.0","date":"2026-05-05","entries":[]},{"version":"1.5354.0","date":"2026-04-29","entries":[]},{"version":"1.5220.0","date":"2026-04-28","entries":[]},{"version":"1.5186.0","date":"2026-04-28","entries":[]},{"version":"1.4758.0","date":"2026-04-24","entries":[]},{"version":"1.4669.0","date":"2026-04-24","entries":[]},{"version":"1.4504.0","date":"2026-04-23","entries":[]},{"version":"1.4304.0","date":"2026-04-22","entries":[]},{"version":"1.3834.0","date":"2026-04-21","entries":[]},{"version":"1.3500