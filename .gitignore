/target
**/*.rs.bk
Cargo.lock.orig

# Local build artefacts / generated graph data are never committed.
/data
/testdata/generated
*.profraw

# Python bytecode from the perf harnesses.
__pycache__/
*.pyc

# Local, uncommitted notes: client-compatibility / Cypher-gap findings produced
# while integrating downstream services. Kept out of git (and survives `git clean`
# being avoided here) so they aren't wiped on rebuilds.
/client-gaps/

perf/datasets

# Out-of-tree build dirs used to work around a stale root-owned lock in /target.
/target-dc
/target-merge
target-merge
