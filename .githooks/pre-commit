#!/usr/bin/env bash
# Pre-commit rustfmt gate — prettier/lint-staged style.
#
# Checks formatting on the Rust files you are *actually committing* (not the whole
# tree), so it never trips on pre-existing formatting elsewhere. A staged file that
# is not rustfmt-clean blocks the commit with a one-line fix.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass in a pinch:       git commit --no-verify
set -euo pipefail

# Staged, still-present Rust files (Added/Copied/Modified/Renamed).
mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR -z \
  | tr '\0' '\n' | grep -E '\.rs$' || true)

[ ${#files[@]} -eq 0 ] && exit 0

# Resolve rustfmt (component of the toolchain). Missing tool ⇒ warn, don't block.
if command -v rustfmt >/dev/null 2>&1; then
  RUSTFMT=rustfmt
elif command -v cargo >/dev/null 2>&1 && cargo fmt --version >/dev/null 2>&1; then
  # Fall back to `cargo fmt` driving rustfmt over the explicit file list.
  RUSTFMT="cargo-fmt-files"
else
  echo "pre-commit: rustfmt not found (install with 'rustup component add rustfmt'); skipping fmt check" >&2
  exit 0
fi

bad=()
for f in "${files[@]}"; do
  [ -f "$f" ] || continue
  if [ "$RUSTFMT" = "cargo-fmt-files" ]; then
    cargo fmt -- --check --edition 2021 "$f" >/dev/null 2>&1 || bad+=("$f")
  else
    # rustfmt auto-discovers any rustfmt.toml up the tree; --edition matches the workspace.
    rustfmt --edition 2021 --check "$f" >/dev/null 2>&1 || bad+=("$f")
  fi
done

if [ ${#bad[@]} -gt 0 ]; then
  echo "✗ rustfmt: the following staged file(s) are not formatted:" >&2
  printf '    %s\n' "${bad[@]}" >&2
  echo "  fix with:  rustfmt --edition 2021 ${bad[*]}    (or: cargo fmt --all)" >&2
  echo "  then 'git add' them and re-commit  (bypass once with --no-verify)" >&2
  exit 1
fi
