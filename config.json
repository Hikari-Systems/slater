{
  "server": {
    "bind": "0.0.0.0",
    "port": 7687,
    "maxConnections": 16384,
    "maxPreAuthConnections": 4096,
    "maxConnectionsPerIp": 1024,
    "maxPreAuthBytes": 65536,
    "maxMessageBytes": 67108864,
    "loginTimeoutMs": 10000,
    "idleTimeoutMs": 0
  },
  "log": {
    "level": "info"
  },
  "dataBackend": {
    "kind": "fs",
    "fs": {
      "dir": "/data"
    }
  },
  "tls": {
    "cert": "",
    "key": ""
  },
  "aclPath": "/config/acl.json",
  "requireAclStamp": true,
  "cache": {
    "blockCacheBytes": 67108864,
    "vectorCacheBytes": 67108864,
    "resultCacheBytes": 16777216
  },
  "vectorIndexPins": [],
  "encryption": {
    "keyEnv": "",
    "keyFile": ""
  },
  "query": {
    "maxRows": 100000,
    "timeoutMs": 30000,
    "maxIntermediate": 1000000,
    "maxScan": 500000000,
    "maxIntermediateGlobal": 8000000,
    "maxShortestPathExplore": 0,
    "maxFanout": 1
  },
  "vectorQuery": {
    "beamWidth": 64,
    "maxHops": 256
  },
  "generationPollMs": 5000,
  "reloadStrategy": "exit",
  "loadTestDiagnostics": false
}
