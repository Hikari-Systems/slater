{
  "server": {
    "bind": "0.0.0.0",
    "port": 7687
  },
  "log": {
    "level": "info"
  },
  "dataDir": "/data",
  "tls": {
    "cert": "",
    "key": ""
  },
  "aclPath": "/config/acl.json",
  "requireAclStamp": true,
  "cache": {
    "blockCacheBytes": 67108864,
    "vectorCacheBytes": 33554432,
    "resultCacheBytes": 16777216
  },
  "vectorIndexPins": [],
  "encryption": {
    "keyEnv": "",
    "keyFile": ""
  },
  "query": {
    "maxRows": 100000,
    "timeoutMs": 30000,
    "maxIntermediate": 1000000,
    "maxShortestPathExplore": 0
  },
  "vectorQuery": {
    "beamWidth": 64,
    "maxHops": 256
  },
  "generationPollMs": 5000,
  "reloadStrategy": "exit"
}
