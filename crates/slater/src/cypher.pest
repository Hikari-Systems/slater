// Read-only Cypher grammar (the query language Slater serves).
//
// This is the ONLINE query grammar, distinct from `slater-build`'s dump dialect
// (`primitive_cypher.pest`). It covers the widened read subset from docs/PLAN.md:
// MATCH (incl. OPTIONAL MATCH), WHERE, WITH, RETURN, UNION[ ALL], relationship
// patterns with type alternation and variable length, map projection, CASE, list
// predicates, function calls/aggregations, and ORDER BY / SKIP / LIMIT / DISTINCT.
//
// Write and procedure clauses are matched as `forbidden_clause` so the translator
// can reject them with a clear "Slater is read-only" message rather than a generic
// parse error.
//
// Every alphabetic keyword is matched through a `kw_*` rule that asserts a trailing
// word boundary (`!ident_cont`), so e.g. `or` never matches the `OR` inside
// `ORDER`, nor `in` the `IN` inside `index`.

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
// Line (`// ŌĆ”`) and block (`/* ŌĆ” */`) comments, matching the openCypher reference
// grammar. Block comments are non-nesting (the first `*/` closes), like C.
COMMENT = _{ ("//" ~ (!"\n" ~ ANY)*) | ("/*" ~ (!"*/" ~ ANY)* ~ "*/") }

// ŌöĆŌöĆ Keyword terminals (word-boundary guarded) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

kw_union = @{ ^"union" ~ !ident_cont }
kw_all = @{ ^"all" ~ !ident_cont }
kw_optional = @{ ^"optional" ~ !ident_cont }
kw_match = @{ ^"match" ~ !ident_cont }
kw_merge = @{ ^"merge" ~ !ident_cont }
kw_where = @{ ^"where" ~ !ident_cont }
kw_return = @{ ^"return" ~ !ident_cont }
kw_with = @{ ^"with" ~ !ident_cont }
kw_distinct = @{ ^"distinct" ~ !ident_cont }
kw_as = @{ ^"as" ~ !ident_cont }
kw_order = @{ ^"order" ~ !ident_cont }
kw_by = @{ ^"by" ~ !ident_cont }
kw_skip = @{ ^"skip" ~ !ident_cont }
kw_limit = @{ ^"limit" ~ !ident_cont }
kw_asc = @{ (^"ascending" | ^"asc") ~ !ident_cont }
kw_desc = @{ (^"descending" | ^"desc") ~ !ident_cont }
kw_or = @{ ^"or" ~ !ident_cont }
kw_and = @{ ^"and" ~ !ident_cont }
kw_xor = @{ ^"xor" ~ !ident_cont }
kw_not = @{ ^"not" ~ !ident_cont }
kw_in = @{ ^"in" ~ !ident_cont }
kw_is = @{ ^"is" ~ !ident_cont }
kw_null = @{ ^"null" ~ !ident_cont }
kw_true = @{ ^"true" ~ !ident_cont }
kw_false = @{ ^"false" ~ !ident_cont }
kw_starts = @{ ^"starts" ~ !ident_cont }
kw_ends = @{ ^"ends" ~ !ident_cont }
kw_contains = @{ ^"contains" ~ !ident_cont }
kw_case = @{ ^"case" ~ !ident_cont }
kw_when = @{ ^"when" ~ !ident_cont }
kw_then = @{ ^"then" ~ !ident_cont }
kw_else = @{ ^"else" ~ !ident_cont }
kw_end = @{ ^"end" ~ !ident_cont }
kw_set = @{ ^"set" ~ !ident_cont }
kw_delete = @{ ^"delete" ~ !ident_cont }
kw_detach = @{ ^"detach" ~ !ident_cont }
kw_call = @{ ^"call" ~ !ident_cont }
kw_yield = @{ ^"yield" ~ !ident_cont }
kw_unwind = @{ ^"unwind" ~ !ident_cont }
// GQL spells UNWIND as `FOR alias IN expr` (PR 5). It lowers onto the very same
// `UnwindClause`, so the executor needs no change ŌĆö only the surface order differs
// (alias-then-expr here, expr-then-alias for UNWIND).
kw_for = @{ ^"for" ~ !ident_cont }
// GQL path restrictors (PR 2). They appear only at the head of a `match_pattern`
// (right after MATCH), never inside `(ŌĆ”)`/`[ŌĆ”]`, so they don't shadow a node or
// relationship variable that happens to be spelled `walk`/`trail`/etc.
kw_walk = @{ ^"walk" ~ !ident_cont }
kw_trail = @{ ^"trail" ~ !ident_cont }
kw_acyclic = @{ ^"acyclic" ~ !ident_cont }
kw_simple = @{ ^"simple" ~ !ident_cont }
// GQL shortest-path selectors (PR 3). Like the restrictors they appear only at the
// head of a `match_pattern`, never inside `(ŌĆ”)`/`[ŌĆ”]`, so a node variable spelled
// `any`/`shortest` is unaffected. `all` reuses the existing `kw_all` (UNION ALL).
kw_any = @{ ^"any" ~ !ident_cont }
kw_shortest = @{ ^"shortest" ~ !ident_cont }
// openCypher shortest-path *functions* used in MATCH position
// (`MATCH p = shortestPath((a)-[:R*]->(b))`). They desugar to the GQL `ANY SHORTEST`
// / `ALL SHORTEST` selectors above (see `lower_shortest_call`). Only valid at the
// head of a `match_pattern`, so a node variable spelled `shortestpath` is unaffected.
kw_shortestpath = @{ ^"shortestpath" ~ !ident_cont }
kw_allshortestpaths = @{ ^"allshortestpaths" ~ !ident_cont }

// ŌöĆŌöĆ Top level ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

// A single optional trailing `;` is tolerated (the openCypher `Statement`
// terminator) ŌĆö many clients/tools append it. Slater serves one statement per RUN,
// so only a *trailing* semicolon is accepted, not a `;`-separated batch.
query = { SOI ~ single_query ~ (union ~ single_query)* ~ ";"? ~ EOI }
union = { kw_union ~ kw_all? }

// ŌöĆŌöĆ Write statement (Phase 1c writable layer) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
// The single durable write shape the writable layer accepts: anchor exactly one
// an existing node by a business key (an inline property equality on a labelled
// node pattern), then overwrite properties. Deliberately narrow ŌĆö one MATCH/MERGE of
// one node pattern, one SET clause of `n.prop = <literal|param>` assignments (or a
// DELETE), an optional RETURN. The anchor keyword sets the create semantics: `MATCH`
// addresses an existing node only (absent ŌåÆ error); `MERGE` creates the node when
// the business key is absent, else patches it (Phase 2c). It is a *separate* parse
// entry (`parser::parse_statement`), tried before the read grammar; broader write
// shapes (multi-node, relationships, REMOVE, computed RHS) are rejected at lowering
// with a clear message, and stay rejected as read-only when the layer is disabled.
// The edge shapes are tried first (they start with the same `(node)` prefix, so a
// node write only reaches its arm when no relationship follows the anchor).
// A leading `UNWIND <list> AS r` turns the node write into a **batched** write: the
// anchor key + SET values may reference `r`'s fields, one write per list element, all
// under a single group commit (write-UNWIND ŌĆö the first step of UNWIND-as-write). The
// unwind arm is tried before the plain node arm; both keep the node tokens inline, so
// `lower_write_statement` handles them uniformly (the `unwind_clause` child, if any,
// marks the batch).
write_statement = {
    SOI ~ (
        edge_write
      | (unwind_clause ~ (kw_match | kw_merge) ~ node_pattern ~ (set_clause | delete_clause) ~ return_clause?)
      | ((kw_match | kw_merge) ~ node_pattern ~ (set_clause | delete_clause) ~ return_clause?)
    ) ~ ";"? ~ EOI
}
set_clause = { kw_set ~ set_item ~ ("," ~ set_item)* }
set_item = { var ~ property_access ~ "=" ~ expr }
// `[DETACH] DELETE var` tombstones the anchored node (Phase 2). DETACH is accepted
// but a no-op until the Phase 3 topology overlay removes incident edges.
delete_clause = { kw_detach? ~ kw_delete ~ var }

// ŌöĆŌöĆ Relationship write (Phase 3c) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
// `MERGE (a:L {k:v})-[:R]->(b:M {j:w})` creates a relationship (create-if-absent by
// edge identity, auto-creating an absent endpoint node); `MATCH (a:L {k:v})-[r:R]->
// (b:M {j:w}) DELETE r` removes one. Both endpoints are single-label, single
// business-key node patterns (same shape as the node anchor); the relationship must
// be a single directed `-[:R]->` with one type and no variable-length / properties
// (validated at lowering, reusing the read grammar's `rel_pattern`). A rel variable
// is required for DELETE (it names the edge) and optional for MERGE.
edge_write = { edge_merge | edge_delete }
edge_merge = { kw_merge ~ node_pattern ~ rel_pattern ~ node_pattern ~ set_clause? }
edge_delete = { kw_match ~ node_pattern ~ rel_pattern ~ node_pattern ~ delete_clause }

// ŌöĆŌöĆ Consolidation trigger (Phase 5) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
// `CALL slater.consolidate()` folds the writable delta into a fresh generation and
// swaps it in. It is a write-layer *admin* operation, so ŌĆö like the node/edge writes
// above ŌĆö it is a `parser::parse_statement` entry rather than a read `call_clause`,
// tried before them. When the writable layer is disabled it never reaches this rule
// (the server calls the read parser, which rejects the `CALL` as read-only), so it is
// deliberately kept out of the read grammar's read-only `read_proc` whitelist.
consolidate_call = { SOI ~ kw_call ~ consolidate_proc ~ "(" ~ ")" ~ ";"? ~ EOI }
consolidate_proc = @{ ^"slater.consolidate" ~ !ident_cont }

// A bare metadata `CALL proc()` (no trailing RETURN) is a complete query ŌĆö its
// yielded outputs are the result columns. The middle alternative greedily
// consumes a `CALL ŌĆ” YIELD ŌĆ” RETURN ŌĆ”` (the call is a `reading_clause`), so the
// trailing `call_clause` only fires for the RETURN-less browser form.
single_query = { forbidden_query | reading_clause* ~ return_clause | call_clause }

// If a query reaches a write/procedure clause we consume the rest verbatim so the
// parse still succeeds and the translator can reject it with a clear "read-only"
// message (rather than the user getting an opaque syntax error).
forbidden_query = { reading_clause* ~ forbidden_clause ~ ANY* }
// `CALL` is forbidden EXCEPT for the single read-only vector procedure (handled by
// `vector_call_clause`): the negative lookahead lets that one form fall through to
// the valid parse while every other procedure call is rejected as read-only.
// `CALL` is forbidden EXCEPT for the read-only vector/metadata procedures and the
// `CALL { ŌĆ” }` subquery: the negative lookaheads let those forms fall through to a
// valid parse while every other procedure call is rejected as read-only. `CALL {`
// (a subquery) is excluded by `!(inline_ws* ~ "{")` so `call_subquery` handles it.
forbidden_clause = @{
    (^"create" | ^"merge" | ^"set" | ^"delete" | ^"remove" | ^"detach"
      | ^"foreach" | ^"load") ~ !ident_cont
  | ^"call" ~ !ident_cont ~ !(inline_ws* ~ "{") ~ !(inline_ws+ ~ (vector_proc | read_proc))
}
inline_ws = _{ " " | "\t" | "\r" | "\n" }

reading_clause = { match_clause | with_clause | vector_call_clause | call_subquery | call_clause | unwind_clause | for_clause }

// `CALL { <subquery> }` (Phase 12): a correlated read-only subquery run once per
// outer row, multiplying cardinality by its returned rows. The inner body is a
// full read query (one or more `UNION`-joined parts); each part may import outer
// variables via a leading `WITH`. A part with no `RETURN` is a unit subquery (it
// passes the outer rows through unchanged). Writes inside are caught by
// `subquery_forbidden` and rejected as read-only, exactly like the top level.
call_subquery = { kw_call ~ "{" ~ subquery ~ "}" }
subquery = { subquery_part ~ (union ~ subquery_part)* }
subquery_part = { subquery_forbidden | reading_clause* ~ return_clause | reading_clause+ }
// Like `forbidden_query` but bounded by the enclosing `}` (it must not swallow the
// closing brace). A write body containing a nested `}` (e.g. a map literal) stops
// early here and then fails the outer `"}"` match ŌĆö still rejected, just with a
// generic parse error rather than the "read-only" message.
subquery_forbidden = { reading_clause* ~ forbidden_clause ~ (!"}" ~ ANY)* }

// UNWIND is a read clause (it multiplies rows over a list); it is NOT forbidden.
unwind_clause = { kw_unwind ~ expr ~ kw_as ~ alias }

// GQL's `FOR alias IN expr` is UNWIND with the operands swapped. It reuses the
// existing `kw_in` (already defined for list membership) and lowers to the same
// `UnwindClause` (parser `lower_for_clause`), so no executor path is duplicated.
for_clause = { kw_for ~ alias ~ kw_in ~ expr }

// The one permitted procedure: brute-force vector KNN. Surfaced as a reading
// clause that binds its YIELD outputs (FalkorDB's `node`, `score`) into scope.
vector_call_clause = {
    kw_call ~ vector_proc ~ "(" ~ func_arg ~ ("," ~ func_arg)* ~ ")" ~ yield_clause ~ where_clause?
}
vector_proc = @{ ^"db.idx.vector.queryNodes" }
yield_clause = { kw_yield ~ yield_item ~ ("," ~ yield_item)* }
yield_item = { identifier ~ (kw_as ~ alias)? }

// Read-only metadata procedures (Phase 11). Unlike the vector procedure these take
// no index/argument and project schema/stat columns. Whitelisted in
// `forbidden_clause`'s negative lookahead so every *other* `CALL` stays rejected as
// read-only. They bind their YIELD outputs (or all outputs, when YIELD is absent)
// into scope like the vector call does.
read_proc = @{
    ^"db.meta.stats" | ^"db.constraints" | ^"dbms.procedures" | ^"dbms.functions"
  // algo.* graph-algorithm procedures (Phase 13). Like the metadata procs, these
  // are arg-bearing reads dispatched through `call_clause`; adding them here also
  // carves them out of `forbidden_clause`'s read-only rejection.
  | ^"algo.BFS" | ^"algo.WCC" | ^"algo.pageRank" | ^"algo.HarmonicCentrality"
  | ^"algo.betweenness" | ^"algo.labelPropagation"
}
call_clause = {
    kw_call ~ read_proc ~ "(" ~ (func_arg ~ ("," ~ func_arg)*)? ~ ")" ~ yield_clause? ~ where_clause?
}

match_clause = { kw_optional? ~ kw_match ~ match_pattern ~ ("," ~ match_pattern)* ~ where_clause? }

with_clause = { kw_with ~ kw_distinct? ~ projection_body ~ where_clause? }

return_clause = { kw_return ~ kw_distinct? ~ projection_body }

projection_body = { projection_items ~ order_by? ~ skip? ~ limit? }
projection_items = { star_item | (projection_item ~ ("," ~ projection_item)*) }
star_item = { "*" ~ ("," ~ projection_item)* }
projection_item = { expr ~ (kw_as ~ alias)? }
alias = { identifier }

order_by = { kw_order ~ kw_by ~ sort_item ~ ("," ~ sort_item)* }
sort_item = { expr ~ (kw_asc | kw_desc)? }
skip = { kw_skip ~ expr }
limit = { kw_limit ~ expr }

where_clause = { kw_where ~ expr }

// ŌöĆŌöĆ Patterns ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

// `PatternElement` may be wrapped in redundant parentheses ŌĆö `MATCH ((a)-[:R]->(b))`
// and `MATCH ((n))` are both legal. The parenthesised arm is tried second: a
// `node_pattern` only accepts `( var? labels? properties? )`, so it fails fast on a
// leading `(` and backtracks cleanly. `lower_pattern_element` flattens the nesting.
pattern = { (path_var ~ "=")? ~ pattern_element }
pattern_element = { (node_pattern ~ (rel_pattern ~ node_pattern)*) | ("(" ~ pattern_element ~ ")") }
path_var = { identifier }

// `match_pattern` is `pattern` plus GQL quantified path patterns. It is used ONLY
// by `match_clause`; the bare `pattern` rule (shortestPath/EXISTS/pattern
// comprehensions) stays quantifier-free so those expression contexts never see a
// segment they can't execute. The leading `shortest_call` alternative accepts the
// openCypher `MATCH p = shortestPath((a)-[:R*]->(b))` spelling (Neo4j/Memgraph
// compatibility), desugaring to the `ANY SHORTEST` / `ALL SHORTEST` selector.
match_pattern = { shortest_call | (path_selector? ~ path_restrictor? ~ (path_var ~ "=")? ~ match_element) }
// `pattern_element` widened with GQL quantified groups, and likewise parenthesisable.
match_element = { (node_pattern ~ ((quantified_path | rel_pattern) ~ node_pattern)*) | ("(" ~ match_element ~ ")") }

// openCypher `shortestPath(...)` / `allShortestPaths(...)` in MATCH position, with an
// optional bound path variable. The inner `pattern` is a single (var-length)
// relationship between two endpoints, matching the GQL selector's scope.
shortest_call = { (path_var ~ "=")? ~ shortest_kind ~ "(" ~ pattern ~ ")" }
shortest_kind = { kw_shortestpath | kw_allshortestpaths }

// GQL shortest-path selector: `ANY SHORTEST` / `ALL SHORTEST` / `SHORTEST k`
// prefixed on a MATCH pattern (e.g. `MATCH ANY SHORTEST (a)-[:R*]->(b)`). It picks
// shortest connecting paths between the pattern's two endpoints; see
// `lower_path_selector` and `apply_match_selected` in exec.rs. Scoped (PR 3) to a
// single-relationship pattern, like `shortestPath()`. `shortest_k` is tried last so
// `ANY SHORTEST` / `ALL SHORTEST` (which start with their own keyword) bind first.
path_selector = { any_shortest | all_shortest | shortest_k }
any_shortest = { kw_any ~ kw_shortest }
all_shortest = { kw_all ~ kw_shortest }
shortest_k = { kw_shortest ~ integer }

// GQL path restrictor: `WALK` / `TRAIL` / `ACYCLIC` / `SIMPLE` prefixed on a MATCH
// pattern (e.g. `MATCH TRAIL (a)-[:R*]->(b)`). It controls node/edge reuse over a
// variable-length walk; see `lower_path_restrictor` and `expand_chain` in exec.rs.
// Scoped (PR 2) to patterns containing a variable-length relationship.
path_restrictor = { kw_walk | kw_trail | kw_acyclic | kw_simple }

// GQL quantified path pattern: a parenthesised sub-path (Ōēź1 relationship) repeated
// `{m,n}` / `{m}` / `{m,}` / `{,n}` / `+` / `*` times, e.g. `((x)-[:R]->(y)){1,3}`.
// Slater desugars a *bounded* quantifier into the union of its fixed-length
// expansions at match time (`expand_quantified_pattern` in exec.rs); unbounded
// forms (`+`, `*`, `{m,}`, `{,n}` open-ended) parse here but are rejected at
// execution for now. Tried before `rel_pattern` in `match_pattern`; it only fires
// on a leading `(` so a normal `-[ŌĆ”]-` relationship falls through cleanly.
quantified_path = { "(" ~ quantified_inner ~ ")" ~ quantifier_bounds }
quantified_inner = { node_pattern ~ (rel_pattern ~ node_pattern)+ }
quantifier_bounds = { exact_bound | range_bound | plus_bound | star_bound }
exact_bound = { "{" ~ integer ~ "}" }
range_bound = { "{" ~ quant_lo? ~ "," ~ quant_hi? ~ "}" }
quant_lo = { integer }
quant_hi = { integer }
plus_bound = { "+" }
star_bound = { "*" }

node_pattern = { "(" ~ var? ~ labels? ~ properties? ~ ")" }

// `Properties = MapLiteral | Parameter`. The parameter spelling (`MATCH (n $p)`)
// parses, but the executor cannot yet turn a runtime map into a pattern
// predicate, so `lower_properties` rejects it with a clear message rather than a
// syntax error.
properties = { prop_map | parameter }

rel_pattern = { left_arrow? ~ dash ~ rel_detail? ~ dash ~ right_arrow? }
// openCypher's `LeftArrowHead` / `RightArrowHead` / `Dash` admit the Unicode
// look-alikes an editor or a word processor silently substitutes ŌĆö the en/em
// dash, the minus sign, the soft hyphen, the fullwidth and small-form variants.
// They are spelled out only here: `SUBTRACT`, `add_op` and `sign` stay ASCII `-`,
// exactly as the reference keeps `Dash` out of its arithmetic productions.
// `dash` is silent so `lower_rel_pattern` still sees only the arrow-head pairs.
left_arrow = { "<" | "Ō¤©" | "ŃĆł" | "’╣ż" | "’╝£" }
right_arrow = { ">" | "Ō¤®" | "ŃĆē" | "’╣ź" | "’╝×" }
dash = _{
    "-" | "\u{00AD}" | "ŌĆÉ" | "ŌĆæ" | "ŌĆÆ" | "ŌĆō" | "ŌĆö" | "ŌĆĢ" | "ŌłÆ" | "’╣ś" | "’╣Ż" | "’╝Ź"
}
rel_detail = { "[" ~ var? ~ rel_types? ~ var_length? ~ properties? ~ "]" }
var_length = { "*" ~ range_spec? }
range_spec = { integer? ~ (".." ~ integer?)? }

// GQL label/type boolean expressions (`!` > `&` > `|`, parens). Both a node's
// `:label_expr` and a relationship's `:label_expr` share one grammar and one AST
// node (`LabelExpr`). The classic sugar still parses into the same tree: `:A:B`
// (the `:` acts as `&`) lowers to AND, and `:T1|T2` / `:T1|:T2` to OR ŌĆö so every
// pre-GQL query is unchanged. `labels`/`rel_types` keep distinct rule names purely
// so the lowering knows which pattern element it is filling in.
labels = { ":" ~ label_expr }
rel_types = { ":" ~ label_expr }
label_expr = { le_or }
le_or = { le_and ~ ("|" ~ ":"? ~ le_and)* }
le_and = { le_not ~ (("&" | ":") ~ le_not)* }
le_not = { le_bang* ~ le_atom }
le_bang = { "!" }
le_atom = { le_name | "(" ~ label_expr ~ ")" }
le_name = { identifier }
var = { identifier }
label_name = { identifier }

prop_map = { "{" ~ (prop_entry ~ ("," ~ prop_entry)*)? ~ "}" }
prop_entry = { property_key ~ ":" ~ expr }
property_key = { identifier }

// ŌöĆŌöĆ Expressions (precedence climbing via nested rules) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

expr = { or_expr }
// openCypher nests these `Or > Xor > And > Not`, so `AND` binds tightest of the
// three and `a XOR b AND c` is `a XOR (b AND c)`. Slater used to nest
// `Or > And > Xor`, which silently flipped that grouping.
or_expr = { xor_expr ~ (kw_or ~ xor_expr)* }
xor_expr = { and_expr ~ (kw_xor ~ and_expr)* }
and_expr = { not_expr ~ (kw_and ~ not_expr)* }
not_expr = { not_op* ~ comparison }
not_op = { kw_not }

comparison = { add_expr ~ comp_rhs* }
comp_rhs = {
    string_op ~ add_expr
  | in_op ~ add_expr
  | null_test
  | comp_op ~ add_expr
}
comp_op = { "=~" | "=" | "<>" | "<=" | ">=" | "<" | ">" }
string_op = { kw_starts ~ kw_with | kw_ends ~ kw_with | kw_contains }
in_op = { kw_in }
null_test = { kw_is ~ kw_not? ~ kw_null }

add_expr = { mul_expr ~ (add_op ~ mul_expr)* }
add_op = { "+" | "-" }
mul_expr = { pow_expr ~ (mul_op ~ pow_expr)* }
mul_op = { "*" | "/" | "%" }
// Exponentiation `^` binds tighter than `* / %` and looser than a unary sign, so
// `-2 ^ 2` is `(-2) ^ 2` ŌĆö matching the openCypher reference grammar (PowerOf sits
// between MultiplyDivideModulo and UnaryAddOrSubtract). Left-associative like the
// reference. `^` always yields a Float (Neo4j semantics), handled at eval.
pow_expr = { unary_expr ~ (pow_op ~ unary_expr)* }
pow_op = { "^" }

unary_expr = { sign* ~ postfix_expr }
sign = { "+" | "-" }

postfix_expr = { primary ~ postfix_op* }
postfix_op = { property_access | label_pred | slice_access | index_access }
property_access = { "." ~ property_key }
label_pred = { ":" ~ label_name ~ (":" ~ label_name)* }
// Slice `list[i..j]` with optional bounds (`[..2]`, `[1..]`, `[..]`). Tried
// before `index_access` so the `..` separator is matched as a range; a plain
// subscript `[i]` backtracks cleanly to `index_access`.
slice_access = { "[" ~ slice_from ~ ".." ~ slice_to ~ "]" }
slice_from = { expr? }
slice_to = { expr? }
index_access = { "[" ~ expr ~ "]" }

primary = {
    case_expr
  | cast_expr
  | exists_subquery
  | reduce_expr
  | list_comprehension
  | shortest_path
  | function_call
  | pattern_predicate
  | map_projection
  | parens
  | pattern_comp
  | list_comp
  | list_literal
  | map_literal
  | literal
  | parameter
  | variable
}

parens = { "(" ~ expr ~ ")" }
variable = { identifier }
// `Parameter = "$" ~ (SymbolicName | DecimalInteger)` ŌĆö positional parameters
// (`$0`, `$1`) are as legal as named ones. The digit arm is tried last because
// `ident_start` never matches a digit.
parameter = { "$" ~ param_name }
param_name = @{ quoted_name | (ident_start ~ ident_cont*) | decimal_int }

// n{.name, .age, alias: expr, .*}
map_projection = { identifier ~ "{" ~ (map_proj_item ~ ("," ~ map_proj_item)*)? ~ "}" }
map_proj_item = { proj_all | proj_property | proj_literal }
proj_all = { ".*" }
proj_property = { "." ~ property_key }
proj_literal = { property_key ~ ":" ~ expr }

function_call = { func_name ~ "(" ~ kw_distinct? ~ (func_arg ~ ("," ~ func_arg)*)? ~ ")" }
// A function name may be namespaced with dots (`list.sort`, `vec.cosineSimilarity`).
// Atomic so the whole dotted path is one token; each segment is still a
// reserved-word-checked identifier.
func_name = @{ identifier ~ ("." ~ identifier)* }
func_arg = { star_arg | expr }
star_arg = { "*" }

// GQL `CAST(expr AS TYPE)` ŌĆö a typed-value conversion. It lowers (parser
// `lower_cast`) onto slater's existing conversion functions (toInteger/toFloat/
// toString/toBoolean and the temporal constructors date/localtime/localdatetime/
// duration), so the executor path is shared, not duplicated. Tried before
// `function_call` in `primary` so `CAST(` is read as a cast, not a plain call;
// a `cast(ŌĆ”)` without the `AS TYPE` tail backtracks cleanly to `function_call`.
cast_expr = { kw_cast ~ "(" ~ expr ~ kw_as ~ cast_type ~ ")" }
kw_cast = @{ ^"cast" ~ !ident_cont }
// The GQL type names slater can convert to, longest-prefix first so `integer`
// wins over `int` etc. (the trailing `!ident_cont` also guards the short forms).
cast_type = @{
    (^"integer" | ^"int" | ^"float" | ^"double" | ^"real" | ^"string"
      | ^"varchar" | ^"boolean" | ^"bool" | ^"localdatetime" | ^"localtime"
      | ^"date" | ^"duration") ~ !ident_cont
}

case_expr = { kw_case ~ case_subject? ~ when_clause+ ~ else_clause? ~ kw_end }
case_subject = { !kw_when ~ expr }
when_clause = { kw_when ~ expr ~ kw_then ~ expr }
else_clause = { kw_else ~ expr }

// any/all/none/single(x IN list WHERE pred)
list_comprehension = { quantifier ~ "(" ~ identifier ~ kw_in ~ expr ~ where_clause? ~ ")" }
quantifier = @{ (^"any" | ^"all" | ^"none" | ^"single") ~ !ident_cont }

// reduce(acc = init, x IN list | expr): fold `expr` over `list`, threading `acc`.
// Tried before `function_call` so `reduce(` is not lowered to a plain call.
reduce_expr = { reduce_kw ~ "(" ~ identifier ~ "=" ~ expr ~ "," ~ identifier ~ kw_in ~ expr ~ "|" ~ expr ~ ")" }
reduce_kw = @{ ^"reduce" ~ !ident_cont }

// List comprehension `[x IN list WHERE pred | expr]`. At least one of the WHERE
// filter / `| expr` projection is required, so a one-element list literal like
// `[a IN b]` (a membership test) still parses as a `list_literal`. Tried before
// `list_literal` in `primary`; it backtracks cleanly when the `ident IN` head is
// absent.
list_comp = { "[" ~ identifier ~ kw_in ~ expr ~ ( (where_clause ~ ("|" ~ expr)?) | ("|" ~ expr) ) ~ "]" }

// Pattern predicate: a bare relationship pattern used as a boolean ŌĆö true iff at
// least one match exists for the surrounding bindings (FalkorDB `op_semi_apply`).
// At least one relationship is required, which disambiguates it from `parens`
// (a bare `(n)` falls through to `parens`/`variable`). Tried before `parens` in
// `primary`; a non-pattern parenthesised expression backtracks cleanly because
// `node_pattern` only accepts `( var? labels? prop_map? )`.
pattern_predicate = { node_pattern ~ (rel_pattern ~ node_pattern)+ }

// `shortestPath((a)-[*]->(b))` ŌĆö a single variable-length relationship between two
// already-bound nodes, evaluated to the shortest connecting path (or NULL). Tried
// before `function_call` in `primary` so the inner pattern is parsed as a pattern,
// not function arguments. (`allShortestPaths` is not yet supported ŌĆö it parses as an
// ordinary `function_call` and is rejected as an unknown function at eval time.)
shortest_path = { shortest_path_kw ~ "(" ~ pattern ~ ")" }
shortest_path_kw = @{ ^"shortestPath" ~ !ident_cont }

// Existential subquery `EXISTS { [MATCH] pattern[, ŌĆ”] [WHERE pred] }` ŌĆö true iff
// the inner pattern (seeded by the outer row's bindings) has Ōēź1 match. Only the
// single-clause read form is supported; a RETURN-bearing or multi-clause inner
// body is deferred to the CALL{} machinery (Phase 12).
// `ExistentialSubquery = EXISTS ~ "{" ~ (RegularQuery | Pattern ~ Where?) ~ "}"`.
// The pattern arm is tried first (it is the only one the executor supports); a
// RETURN-bearing or multi-clause body falls through to `subquery`, which parses
// so `lower_exists` can reject it by name instead of as a syntax error.
// The `&"}"` is load-bearing. Without it the pattern arm succeeds on the `MATCH (a)`
// prefix of `EXISTS { MATCH (a) RETURN a }`, the following `"}"` then fails, and an
// ordered choice never retries the arm it already committed to ŌĆö so the RegularQuery
// arm would be unreachable. The lookahead makes the pattern arm claim the body only
// when it has consumed all of it.
exists_subquery = {
    exists_kw ~ "{" ~ (
        (kw_match? ~ pattern ~ ("," ~ pattern)* ~ where_clause? ~ &"}")
      | subquery
    ) ~ "}"
}
exists_kw = @{ ^"exists" ~ !ident_cont }

// Pattern comprehension `[(a)-[:R]->(b) WHERE pred | expr]`: a relationship
// pattern (seeded by already-bound nodes), an optional filter, and a mandatory
// `| expr` projection collected per match. Tried before `list_literal`/`list_comp`
// in `primary`; its `(` head is unambiguous against both.
pattern_comp = { "[" ~ pattern ~ where_clause? ~ "|" ~ expr ~ "]" }

list_literal = { "[" ~ (expr ~ ("," ~ expr)*)? ~ "]" }
map_literal = { "{" ~ (map_lit_entry ~ ("," ~ map_lit_entry)*)? ~ "}" }
map_lit_entry = { property_key ~ ":" ~ expr }

// ŌöĆŌöĆ Literals ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

literal = { float | integer | boolean | null | string }
null = { kw_null }
boolean = { kw_true | kw_false }
// openCypher `IntegerLiteral = HexInteger | OctalInteger | DecimalInteger`. The
// three radices are ordered so the longest prefix wins: `0xŌĆ”` is hex, a leading
// `0` followed by octal digits is OCTAL (`017` is 15, not 17), and everything
// else is decimal. Because `DecimalInteger` is `0 | (1-9) digit*`, a leading zero
// followed by a non-octal digit (`08`, `09`) is not an integer at all ŌĆö the `0`
// matches and the stray digit fails the enclosing rule, exactly as the reference
// grammar does. The optional `-` is Slater's own (the reference spells negation
// as a separate unary operator); it costs nothing and keeps `-1` a single token.
integer = @{ "-"? ~ (hex_int | octal_int | decimal_int) }
hex_int = _{ ^"0x" ~ ASCII_HEX_DIGIT+ }
octal_int = _{ "0" ~ ASCII_OCT_DIGIT+ }
decimal_int = _{ "0" | (ASCII_NONZERO_DIGIT ~ ASCII_DIGIT*) }
// A double literal, tried before `integer` in `literal` so a fractional/exponent
// form wins. Two shapes, matching the openCypher reference `DoubleLiteral`:
//   * a decimal point with a fractional part ŌĆö `1.5`, `.5` (no integer part), each
//     with an optional exponent (`1.5e3`, `.5E-2`);
//   * an integer mantissa with a *required* exponent ŌĆö `1e10` (no decimal point).
// A plain `123` (no dot, no exponent) fails both shapes and falls through to
// `integer`. Rust's `f64::from_str` parses every string this rule accepts.
float = @{
    ("-")? ~ (
        (ASCII_DIGIT* ~ "." ~ ASCII_DIGIT+ ~ (^"e" ~ ("+" | "-")? ~ ASCII_DIGIT+)?)
      | (ASCII_DIGIT+ ~ ^"e" ~ ("+" | "-")? ~ ASCII_DIGIT+)
    )
}
string = ${ "'" ~ sq_inner ~ "'" | "\"" ~ dq_inner ~ "\"" }
sq_inner = @{ (escape | (!"'" ~ !"\\" ~ ANY))* }
dq_inner = @{ (escape | (!"\"" ~ !"\\" ~ ANY))* }
escape = @{ "\\" ~ ANY }

// Identifiers: backtick-quoted or a bare name.
//
// openCypher's `SymbolicName` is `UnescapedSymbolicName | EscapedSymbolicName |
// ŌĆ”`, and `UnescapedSymbolicName = IdentifierStart ~ IdentifierPart*` ŌĆö which
// matches every reserved word too. Its `ReservedWord` production is referenced
// only from `SchemaName = SymbolicName | ReservedWord`, so in the reference
// grammar `SchemaName` and `SymbolicName` accept exactly the same strings and no
// bare name is ever excluded. Slater used to carry a `!reserved` guard here,
// which rejected the legal `MATCH (n:Order)`, `RETURN n.end` and `{limit: 1}`.
// The guard is gone; a keyword only wins where the grammar asks for a `kw_*`
// terminal, and those still assert a trailing `!ident_cont` word boundary, so
// `RETURNS` is not `RETURN`, and `n.order` is a property lookup, not an ORDER BY.
identifier = @{ quoted_name | (ident_start ~ ident_cont*) }

// `EscapedSymbolicName = ("`" ~ (!"`" ~ ANY)* ~ "`")+` ŌĆö the `+` is how a literal
// backtick is escaped inside a quoted name (`` `a``b` `` is the single name
// ``a`b``), and the `*` lets `` `` `` name the empty string.
quoted_name = _{ ("`" ~ (!"`" ~ ANY)* ~ "`")+ }

// `IdentifierStart = ID_Start | Pc`, `IdentifierPart = ID_Continue | Sc`. Unicode,
// not ASCII: `caf├®` and `ŽĆ` are names, and `_` arrives via connector punctuation.
// These also back every keyword's `!ident_cont` boundary guard, so a keyword
// followed by a non-ASCII letter (`ORDER├®`) is correctly read as one name.
ident_start = _{ ID_START | CONNECTOR_PUNCTUATION }
ident_cont = _{ ID_CONTINUE | CURRENCY_SYMBOL }
