// Read-only Cypher grammar (the query language Slater serves).
//
// This is the ONLINE query grammar, distinct from `slater-build`'s dump dialect
// (`primitive_cypher.pest`). It covers the widened read subset from docs/PLAN.md:
// MATCH (incl. OPTIONAL MATCH), WHERE, WITH, RETURN, UNION[ ALL], relationship
// patterns with type alternation and variable length, map projection, CASE, list
// predicates, function calls/aggregations, and ORDER BY / SKIP / LIMIT / DISTINCT.
//
// Write and procedure clauses are matched as `forbidden_clause` so the translator
// can reject them with a clear "Slater is read-only" message rather than a generic
// parse error.
//
// Every alphabetic keyword is matched through a `kw_*` rule that asserts a trailing
// word boundary (`!ident_cont`), so e.g. `or` never matches the `OR` inside
// `ORDER`, nor `in` the `IN` inside `index`.

WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT = _{ "//" ~ (!"\n" ~ ANY)* }

// ── Keyword terminals (word-boundary guarded) ───────────────────────────────

kw_union = @{ ^"union" ~ !ident_cont }
kw_all = @{ ^"all" ~ !ident_cont }
kw_optional = @{ ^"optional" ~ !ident_cont }
kw_match = @{ ^"match" ~ !ident_cont }
kw_where = @{ ^"where" ~ !ident_cont }
kw_return = @{ ^"return" ~ !ident_cont }
kw_with = @{ ^"with" ~ !ident_cont }
kw_distinct = @{ ^"distinct" ~ !ident_cont }
kw_as = @{ ^"as" ~ !ident_cont }
kw_order = @{ ^"order" ~ !ident_cont }
kw_by = @{ ^"by" ~ !ident_cont }
kw_skip = @{ ^"skip" ~ !ident_cont }
kw_limit = @{ ^"limit" ~ !ident_cont }
kw_asc = @{ (^"ascending" | ^"asc") ~ !ident_cont }
kw_desc = @{ (^"descending" | ^"desc") ~ !ident_cont }
kw_or = @{ ^"or" ~ !ident_cont }
kw_and = @{ ^"and" ~ !ident_cont }
kw_xor = @{ ^"xor" ~ !ident_cont }
kw_not = @{ ^"not" ~ !ident_cont }
kw_in = @{ ^"in" ~ !ident_cont }
kw_is = @{ ^"is" ~ !ident_cont }
kw_null = @{ ^"null" ~ !ident_cont }
kw_true = @{ ^"true" ~ !ident_cont }
kw_false = @{ ^"false" ~ !ident_cont }
kw_starts = @{ ^"starts" ~ !ident_cont }
kw_ends = @{ ^"ends" ~ !ident_cont }
kw_contains = @{ ^"contains" ~ !ident_cont }
kw_case = @{ ^"case" ~ !ident_cont }
kw_when = @{ ^"when" ~ !ident_cont }
kw_then = @{ ^"then" ~ !ident_cont }
kw_else = @{ ^"else" ~ !ident_cont }
kw_end = @{ ^"end" ~ !ident_cont }
kw_call = @{ ^"call" ~ !ident_cont }
kw_yield = @{ ^"yield" ~ !ident_cont }
kw_unwind = @{ ^"unwind" ~ !ident_cont }
// GQL path restrictors (PR 2). They appear only at the head of a `match_pattern`
// (right after MATCH), never inside `(…)`/`[…]`, so they don't shadow a node or
// relationship variable that happens to be spelled `walk`/`trail`/etc.
kw_walk = @{ ^"walk" ~ !ident_cont }
kw_trail = @{ ^"trail" ~ !ident_cont }
kw_acyclic = @{ ^"acyclic" ~ !ident_cont }
kw_simple = @{ ^"simple" ~ !ident_cont }
// GQL shortest-path selectors (PR 3). Like the restrictors they appear only at the
// head of a `match_pattern`, never inside `(…)`/`[…]`, so a node variable spelled
// `any`/`shortest` is unaffected. `all` reuses the existing `kw_all` (UNION ALL).
kw_any = @{ ^"any" ~ !ident_cont }
kw_shortest = @{ ^"shortest" ~ !ident_cont }

// ── Top level ────────────────────────────────────────────────────────────────

query = { SOI ~ single_query ~ (union ~ single_query)* ~ EOI }
union = { kw_union ~ kw_all? }

// A bare metadata `CALL proc()` (no trailing RETURN) is a complete query — its
// yielded outputs are the result columns. The middle alternative greedily
// consumes a `CALL … YIELD … RETURN …` (the call is a `reading_clause`), so the
// trailing `call_clause` only fires for the RETURN-less browser form.
single_query = { forbidden_query | reading_clause* ~ return_clause | call_clause }

// If a query reaches a write/procedure clause we consume the rest verbatim so the
// parse still succeeds and the translator can reject it with a clear "read-only"
// message (rather than the user getting an opaque syntax error).
forbidden_query = { reading_clause* ~ forbidden_clause ~ ANY* }
// `CALL` is forbidden EXCEPT for the single read-only vector procedure (handled by
// `vector_call_clause`): the negative lookahead lets that one form fall through to
// the valid parse while every other procedure call is rejected as read-only.
// `CALL` is forbidden EXCEPT for the read-only vector/metadata procedures and the
// `CALL { … }` subquery: the negative lookaheads let those forms fall through to a
// valid parse while every other procedure call is rejected as read-only. `CALL {`
// (a subquery) is excluded by `!(inline_ws* ~ "{")` so `call_subquery` handles it.
forbidden_clause = @{
    (^"create" | ^"merge" | ^"set" | ^"delete" | ^"remove" | ^"detach"
      | ^"foreach" | ^"load") ~ !ident_cont
  | ^"call" ~ !ident_cont ~ !(inline_ws* ~ "{") ~ !(inline_ws+ ~ (vector_proc | read_proc))
}
inline_ws = _{ " " | "\t" | "\r" | "\n" }

reading_clause = { match_clause | with_clause | vector_call_clause | call_subquery | call_clause | unwind_clause }

// `CALL { <subquery> }` (Phase 12): a correlated read-only subquery run once per
// outer row, multiplying cardinality by its returned rows. The inner body is a
// full read query (one or more `UNION`-joined parts); each part may import outer
// variables via a leading `WITH`. A part with no `RETURN` is a unit subquery (it
// passes the outer rows through unchanged). Writes inside are caught by
// `subquery_forbidden` and rejected as read-only, exactly like the top level.
call_subquery = { kw_call ~ "{" ~ subquery ~ "}" }
subquery = { subquery_part ~ (union ~ subquery_part)* }
subquery_part = { subquery_forbidden | reading_clause* ~ return_clause | reading_clause+ }
// Like `forbidden_query` but bounded by the enclosing `}` (it must not swallow the
// closing brace). A write body containing a nested `}` (e.g. a map literal) stops
// early here and then fails the outer `"}"` match — still rejected, just with a
// generic parse error rather than the "read-only" message.
subquery_forbidden = { reading_clause* ~ forbidden_clause ~ (!"}" ~ ANY)* }

// UNWIND is a read clause (it multiplies rows over a list); it is NOT forbidden.
unwind_clause = { kw_unwind ~ expr ~ kw_as ~ alias }

// The one permitted procedure: brute-force vector KNN. Surfaced as a reading
// clause that binds its YIELD outputs (FalkorDB's `node`, `score`) into scope.
vector_call_clause = {
    kw_call ~ vector_proc ~ "(" ~ func_arg ~ ("," ~ func_arg)* ~ ")" ~ yield_clause ~ where_clause?
}
vector_proc = @{ ^"db.idx.vector.queryNodes" }
yield_clause = { kw_yield ~ yield_item ~ ("," ~ yield_item)* }
yield_item = { identifier ~ (kw_as ~ alias)? }

// Read-only metadata procedures (Phase 11). Unlike the vector procedure these take
// no index/argument and project schema/stat columns. Whitelisted in
// `forbidden_clause`'s negative lookahead so every *other* `CALL` stays rejected as
// read-only. They bind their YIELD outputs (or all outputs, when YIELD is absent)
// into scope like the vector call does.
read_proc = @{
    ^"db.meta.stats" | ^"db.constraints" | ^"dbms.procedures" | ^"dbms.functions"
  // algo.* graph-algorithm procedures (Phase 13). Like the metadata procs, these
  // are arg-bearing reads dispatched through `call_clause`; adding them here also
  // carves them out of `forbidden_clause`'s read-only rejection.
  | ^"algo.BFS" | ^"algo.WCC" | ^"algo.pageRank" | ^"algo.HarmonicCentrality"
  | ^"algo.betweenness" | ^"algo.labelPropagation"
}
call_clause = {
    kw_call ~ read_proc ~ "(" ~ (func_arg ~ ("," ~ func_arg)*)? ~ ")" ~ yield_clause? ~ where_clause?
}

match_clause = { kw_optional? ~ kw_match ~ match_pattern ~ ("," ~ match_pattern)* ~ where_clause? }

with_clause = { kw_with ~ kw_distinct? ~ projection_body ~ where_clause? }

return_clause = { kw_return ~ kw_distinct? ~ projection_body }

projection_body = { projection_items ~ order_by? ~ skip? ~ limit? }
projection_items = { star_item | (projection_item ~ ("," ~ projection_item)*) }
star_item = { "*" ~ ("," ~ projection_item)* }
projection_item = { expr ~ (kw_as ~ alias)? }
alias = { identifier }

order_by = { kw_order ~ kw_by ~ sort_item ~ ("," ~ sort_item)* }
sort_item = { expr ~ (kw_asc | kw_desc)? }
skip = { kw_skip ~ expr }
limit = { kw_limit ~ expr }

where_clause = { kw_where ~ expr }

// ── Patterns ─────────────────────────────────────────────────────────────────

pattern = { (path_var ~ "=")? ~ node_pattern ~ (rel_pattern ~ node_pattern)* }
path_var = { identifier }

// `match_pattern` is `pattern` plus GQL quantified path patterns. It is used ONLY
// by `match_clause`; the bare `pattern` rule (shortestPath/EXISTS/pattern
// comprehensions) stays quantifier-free so those expression contexts never see a
// segment they can't execute.
match_pattern = { path_selector? ~ path_restrictor? ~ (path_var ~ "=")? ~ node_pattern ~ ((quantified_path | rel_pattern) ~ node_pattern)* }

// GQL shortest-path selector: `ANY SHORTEST` / `ALL SHORTEST` / `SHORTEST k`
// prefixed on a MATCH pattern (e.g. `MATCH ANY SHORTEST (a)-[:R*]->(b)`). It picks
// shortest connecting paths between the pattern's two endpoints; see
// `lower_path_selector` and `apply_match_selected` in exec.rs. Scoped (PR 3) to a
// single-relationship pattern, like `shortestPath()`. `shortest_k` is tried last so
// `ANY SHORTEST` / `ALL SHORTEST` (which start with their own keyword) bind first.
path_selector = { any_shortest | all_shortest | shortest_k }
any_shortest = { kw_any ~ kw_shortest }
all_shortest = { kw_all ~ kw_shortest }
shortest_k = { kw_shortest ~ integer }

// GQL path restrictor: `WALK` / `TRAIL` / `ACYCLIC` / `SIMPLE` prefixed on a MATCH
// pattern (e.g. `MATCH TRAIL (a)-[:R*]->(b)`). It controls node/edge reuse over a
// variable-length walk; see `lower_path_restrictor` and `expand_chain` in exec.rs.
// Scoped (PR 2) to patterns containing a variable-length relationship.
path_restrictor = { kw_walk | kw_trail | kw_acyclic | kw_simple }

// GQL quantified path pattern: a parenthesised sub-path (≥1 relationship) repeated
// `{m,n}` / `{m}` / `{m,}` / `{,n}` / `+` / `*` times, e.g. `((x)-[:R]->(y)){1,3}`.
// Slater desugars a *bounded* quantifier into the union of its fixed-length
// expansions at match time (`expand_quantified_pattern` in exec.rs); unbounded
// forms (`+`, `*`, `{m,}`, `{,n}` open-ended) parse here but are rejected at
// execution for now. Tried before `rel_pattern` in `match_pattern`; it only fires
// on a leading `(` so a normal `-[…]-` relationship falls through cleanly.
quantified_path = { "(" ~ quantified_inner ~ ")" ~ quantifier_bounds }
quantified_inner = { node_pattern ~ (rel_pattern ~ node_pattern)+ }
quantifier_bounds = { exact_bound | range_bound | plus_bound | star_bound }
exact_bound = { "{" ~ integer ~ "}" }
range_bound = { "{" ~ quant_lo? ~ "," ~ quant_hi? ~ "}" }
quant_lo = { integer }
quant_hi = { integer }
plus_bound = { "+" }
star_bound = { "*" }

node_pattern = { "(" ~ var? ~ labels? ~ prop_map? ~ ")" }

rel_pattern = { left_arrow? ~ "-" ~ rel_detail? ~ "-" ~ right_arrow? }
left_arrow = { "<" }
right_arrow = { ">" }
rel_detail = { "[" ~ var? ~ rel_types? ~ var_length? ~ prop_map? ~ "]" }
var_length = { "*" ~ range_spec? }
range_spec = { integer? ~ (".." ~ integer?)? }

// GQL label/type boolean expressions (`!` > `&` > `|`, parens). Both a node's
// `:label_expr` and a relationship's `:label_expr` share one grammar and one AST
// node (`LabelExpr`). The classic sugar still parses into the same tree: `:A:B`
// (the `:` acts as `&`) lowers to AND, and `:T1|T2` / `:T1|:T2` to OR — so every
// pre-GQL query is unchanged. `labels`/`rel_types` keep distinct rule names purely
// so the lowering knows which pattern element it is filling in.
labels = { ":" ~ label_expr }
rel_types = { ":" ~ label_expr }
label_expr = { le_or }
le_or = { le_and ~ ("|" ~ ":"? ~ le_and)* }
le_and = { le_not ~ (("&" | ":") ~ le_not)* }
le_not = { le_bang* ~ le_atom }
le_bang = { "!" }
le_atom = { le_name | "(" ~ label_expr ~ ")" }
le_name = { identifier }
var = { identifier }
label_name = { identifier }

prop_map = { "{" ~ (prop_entry ~ ("," ~ prop_entry)*)? ~ "}" }
prop_entry = { property_key ~ ":" ~ expr }
property_key = { identifier }

// ── Expressions (precedence climbing via nested rules) ───────────────────────

expr = { or_expr }
or_expr = { and_expr ~ (kw_or ~ and_expr)* }
and_expr = { xor_expr ~ (kw_and ~ xor_expr)* }
xor_expr = { not_expr ~ (kw_xor ~ not_expr)* }
not_expr = { not_op* ~ comparison }
not_op = { kw_not }

comparison = { add_expr ~ comp_rhs* }
comp_rhs = {
    string_op ~ add_expr
  | in_op ~ add_expr
  | null_test
  | comp_op ~ add_expr
}
comp_op = { "=~" | "=" | "<>" | "<=" | ">=" | "<" | ">" }
string_op = { kw_starts ~ kw_with | kw_ends ~ kw_with | kw_contains }
in_op = { kw_in }
null_test = { kw_is ~ kw_not? ~ kw_null }

add_expr = { mul_expr ~ (add_op ~ mul_expr)* }
add_op = { "+" | "-" }
mul_expr = { unary_expr ~ (mul_op ~ unary_expr)* }
mul_op = { "*" | "/" | "%" }

unary_expr = { sign* ~ postfix_expr }
sign = { "+" | "-" }

postfix_expr = { primary ~ postfix_op* }
postfix_op = { property_access | label_pred | slice_access | index_access }
property_access = { "." ~ property_key }
label_pred = { ":" ~ label_name ~ (":" ~ label_name)* }
// Slice `list[i..j]` with optional bounds (`[..2]`, `[1..]`, `[..]`). Tried
// before `index_access` so the `..` separator is matched as a range; a plain
// subscript `[i]` backtracks cleanly to `index_access`.
slice_access = { "[" ~ slice_from ~ ".." ~ slice_to ~ "]" }
slice_from = { expr? }
slice_to = { expr? }
index_access = { "[" ~ expr ~ "]" }

primary = {
    case_expr
  | exists_subquery
  | reduce_expr
  | list_comprehension
  | shortest_path
  | function_call
  | pattern_predicate
  | map_projection
  | parens
  | pattern_comp
  | list_comp
  | list_literal
  | map_literal
  | literal
  | parameter
  | variable
}

parens = { "(" ~ expr ~ ")" }
variable = { identifier }
// A parameter name may be a reserved word (e.g. `$limit`), so it is not
// reserved-checked the way a bare identifier is.
parameter = { "$" ~ param_name }
param_name = @{ "`" ~ (!"`" ~ ANY)+ ~ "`" | ident_start ~ ident_cont* }

// n{.name, .age, alias: expr, .*}
map_projection = { identifier ~ "{" ~ (map_proj_item ~ ("," ~ map_proj_item)*)? ~ "}" }
map_proj_item = { proj_all | proj_property | proj_literal }
proj_all = { ".*" }
proj_property = { "." ~ property_key }
proj_literal = { property_key ~ ":" ~ expr }

function_call = { func_name ~ "(" ~ kw_distinct? ~ (func_arg ~ ("," ~ func_arg)*)? ~ ")" }
// A function name may be namespaced with dots (`list.sort`, `vec.cosineSimilarity`).
// Atomic so the whole dotted path is one token; each segment is still a
// reserved-word-checked identifier.
func_name = @{ identifier ~ ("." ~ identifier)* }
func_arg = { star_arg | expr }
star_arg = { "*" }

case_expr = { kw_case ~ case_subject? ~ when_clause+ ~ else_clause? ~ kw_end }
case_subject = { !kw_when ~ expr }
when_clause = { kw_when ~ expr ~ kw_then ~ expr }
else_clause = { kw_else ~ expr }

// any/all/none/single(x IN list WHERE pred)
list_comprehension = { quantifier ~ "(" ~ identifier ~ kw_in ~ expr ~ where_clause? ~ ")" }
quantifier = @{ (^"any" | ^"all" | ^"none" | ^"single") ~ !ident_cont }

// reduce(acc = init, x IN list | expr): fold `expr` over `list`, threading `acc`.
// Tried before `function_call` so `reduce(` is not lowered to a plain call.
reduce_expr = { reduce_kw ~ "(" ~ identifier ~ "=" ~ expr ~ "," ~ identifier ~ kw_in ~ expr ~ "|" ~ expr ~ ")" }
reduce_kw = @{ ^"reduce" ~ !ident_cont }

// List comprehension `[x IN list WHERE pred | expr]`. At least one of the WHERE
// filter / `| expr` projection is required, so a one-element list literal like
// `[a IN b]` (a membership test) still parses as a `list_literal`. Tried before
// `list_literal` in `primary`; it backtracks cleanly when the `ident IN` head is
// absent.
list_comp = { "[" ~ identifier ~ kw_in ~ expr ~ ( (where_clause ~ ("|" ~ expr)?) | ("|" ~ expr) ) ~ "]" }

// Pattern predicate: a bare relationship pattern used as a boolean — true iff at
// least one match exists for the surrounding bindings (FalkorDB `op_semi_apply`).
// At least one relationship is required, which disambiguates it from `parens`
// (a bare `(n)` falls through to `parens`/`variable`). Tried before `parens` in
// `primary`; a non-pattern parenthesised expression backtracks cleanly because
// `node_pattern` only accepts `( var? labels? prop_map? )`.
pattern_predicate = { node_pattern ~ (rel_pattern ~ node_pattern)+ }

// `shortestPath((a)-[*]->(b))` — a single variable-length relationship between two
// already-bound nodes, evaluated to the shortest connecting path (or NULL). Tried
// before `function_call` in `primary` so the inner pattern is parsed as a pattern,
// not function arguments. (`allShortestPaths` is not yet supported — it parses as an
// ordinary `function_call` and is rejected as an unknown function at eval time.)
shortest_path = { shortest_path_kw ~ "(" ~ pattern ~ ")" }
shortest_path_kw = @{ ^"shortestPath" ~ !ident_cont }

// Existential subquery `EXISTS { [MATCH] pattern[, …] [WHERE pred] }` — true iff
// the inner pattern (seeded by the outer row's bindings) has ≥1 match. Only the
// single-clause read form is supported; a RETURN-bearing or multi-clause inner
// body is deferred to the CALL{} machinery (Phase 12).
exists_subquery = { exists_kw ~ "{" ~ kw_match? ~ pattern ~ ("," ~ pattern)* ~ where_clause? ~ "}" }
exists_kw = @{ ^"exists" ~ !ident_cont }

// Pattern comprehension `[(a)-[:R]->(b) WHERE pred | expr]`: a relationship
// pattern (seeded by already-bound nodes), an optional filter, and a mandatory
// `| expr` projection collected per match. Tried before `list_literal`/`list_comp`
// in `primary`; its `(` head is unambiguous against both.
pattern_comp = { "[" ~ pattern ~ where_clause? ~ "|" ~ expr ~ "]" }

list_literal = { "[" ~ (expr ~ ("," ~ expr)*)? ~ "]" }
map_literal = { "{" ~ (map_lit_entry ~ ("," ~ map_lit_entry)*)? ~ "}" }
map_lit_entry = { property_key ~ ":" ~ expr }

// ── Literals ─────────────────────────────────────────────────────────────────

literal = { float | integer | boolean | null | string }
null = { kw_null }
boolean = { kw_true | kw_false }
integer = @{ ("-")? ~ ASCII_DIGIT+ }
float = @{ ("-")? ~ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ ~ (^"e" ~ ("+" | "-")? ~ ASCII_DIGIT+)? }
string = ${ "'" ~ sq_inner ~ "'" | "\"" ~ dq_inner ~ "\"" }
sq_inner = @{ (escape | (!"'" ~ !"\\" ~ ANY))* }
dq_inner = @{ (escape | (!"\"" ~ !"\\" ~ ANY))* }
escape = @{ "\\" ~ ANY }

// Identifiers: backtick-quoted or a plain ident that is not a reserved word.
identifier = @{ "`" ~ (!"`" ~ ANY)+ ~ "`" | (!reserved ~ ident_start ~ ident_cont*) }
ident_start = _{ ASCII_ALPHA | "_" }
ident_cont = _{ ASCII_ALPHANUMERIC | "_" }

// Reserved words may not be bare identifiers (so `RETURN return` etc. fail). The
// trailing !ident_cont guard stops `count` matching the prefix of `countries`.
reserved = _{
    (^"match" | ^"optional" | ^"where" | ^"return" | ^"with" | ^"order" | ^"by"
      | ^"skip" | ^"limit" | ^"distinct" | ^"as" | ^"and" | ^"or" | ^"xor"
      | ^"not" | ^"in" | ^"is" | ^"null" | ^"true" | ^"false" | ^"case"
      | ^"when" | ^"then" | ^"else" | ^"end" | ^"contains" | ^"starts"
      | ^"ends" | ^"union" | ^"ascending" | ^"asc" | ^"descending" | ^"desc"
      | ^"call" | ^"yield" | ^"unwind")
    ~ !ident_cont
}
